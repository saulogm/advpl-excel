/*/{Protheus.doc} ChartArea
Grßfico de ßrea (c:areaChart / c:area3DChart - ECMA-376 ¦21.2.2.5)
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@type class
@see custom.excel.chart.Chart
/*/
Class ChartArea from Chart
	Public Data cAgrupamento	As Character	//Agrupamento: standard, stacked, percentStacked

	Public Method New()				As Object
	Public Method SetAgrupamento()	As Object
	Public Method XmlPlot()
	Public Method XmlGrupo()
	Public Method XmlSer()
EndClass

/*/{Protheus.doc} ChartArea::New
Construtor do grßfico de ßrea
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@param oExcel, object, InstŌncia da classe custom.excel.Xlsx
@return object, self
@type method
/*/
Method New(oExcel As Object) as Object Class ChartArea
	_Super:New(oExcel)
	::cClassName	:= "CUSTOM.EXCEL.CHART.CHARTAREA"
	::cAgrupamento	:= "standard"
Return self

/*/{Protheus.doc} ChartArea::SetAgrupamento
Define o agrupamento das sķries
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@param cAgrupamento, characters, standard=normal, stacked=empilhado, percentStacked=100% empilhado
@return object, self
@type method
/*/
Method SetAgrupamento(cAgrupamento As Character) as Object Class ChartArea
	PARAMTYPE 0	VAR cAgrupamento	AS CHARACTER
	If !(cAgrupamento=="standard" .or. cAgrupamento=="stacked" .or. cAgrupamento=="percentStacked")
		UserException("ChartArea - Agrupamento invßlido ("+cAgrupamento+"). Usar: standard,stacked,percentStacked")
	Endif
	::cAgrupamento	:= cAgrupamento
Return self

/*/{Protheus.doc} ChartArea::XmlPlot
Gera o c:areaChart/c:area3DChart e os eixos
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@return characters, XML do plotArea
@type method
/*/
Method XmlPlot() Class ChartArea
	Local cXml := ::XmlGrupo(0) As Character
	cXml	+= ::XmlEixos("b","l")
	If ::l3D
		cXml	+= ::XmlEixoSer()
	Endif
Return cXml

/*/{Protheus.doc} ChartArea::XmlGrupo
Gera somente o grupo do grßfico (c:areaChart/c:area3DChart), sem os eixos.
Usado pelo XmlPlot e pela combinańŃo de grßficos (ChartCombo).
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@param nIdxIni, numeric, ═ndice inicial das sķries (para combinańŃo)
@return characters, XML do grupo
@type method
/*/
Method XmlGrupo(nIdxIni As Numeric) Class ChartArea
	Local cXml := "" As Character
	Local nCont As Numeric
	Local cTag As Character
	PARAMTYPE 0	VAR nIdxIni		AS NUMERIC	OPTIONAL DEFAULT 0
	cTag	:= If(::l3D,"c:area3DChart","c:areaChart")
	cXml	+= '<'+cTag+'>'
	cXml	+= '<c:grouping val="'+::cAgrupamento+'"/>'
	cXml	+= '<c:varyColors val="0"/>'
	For nCont:=1 to Len(::aSeries)
		cXml	+= ::XmlSer(::aSeries[nCont],nIdxIni+nCont-1)
	Next
	If ::l3D
		cXml	+= '<c:gapDepth val="150"/>'
	Endif
	cXml	+= '<c:axId val="'+cValToChar(::nIdEixo1)+'"/>'
	cXml	+= '<c:axId val="'+cValToChar(::nIdEixo2)+'"/>'
	If ::l3D
		cXml	+= '<c:axId val="'+cValToChar(::nIdEixo3)+'"/>'
	Endif
	cXml	+= '</'+cTag+'>'
Return cXml

/*/{Protheus.doc} ChartArea::XmlSer
Gera uma sķrie do grßfico de ßrea (c:ser)
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@param oSerie, object, Objeto Serie
@param nIdx, numeric, ═ndice da sķrie (base zero)
@return characters, XML da sķrie
@type method
/*/
Method XmlSer(oSerie As Object, nIdx As Numeric) Class ChartArea
	Local cXml := "" As Character
	cXml	+= XmlSerIni(oSerie,nIdx)
	If !Empty(oSerie:cCor)
		cXml	+= '<c:spPr>'+XmlCor(oSerie:cCor)+'</c:spPr>'	//Cor = preenchimento da ßrea
	Endif
	cXml	+= XmlCat(oSerie)
	cXml	+= XmlVal(oSerie)
	cXml	+= '</c:ser>'
Return cXml

//----------------------------------------------------------------------
//GR┴FICO DE AŪšES
//----------------------------------------------------------------------
/*/{Protheus.doc} ChartStock
Grßfico de ań§es (c:stockChart - ECMA-376 ¦21.2.2.198)
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@type class
@see custom.excel.chart.Chart
@obs As sķries devem ser adicionadas em ORDEM FIXA:
3 sķries = HLC: Mßxima, MĒnima, Fechamento
4 sķries = OHLC: Abertura, Mßxima, MĒnima, Fechamento (gera barras de alta/baixa)
/*/
Class ChartStock from Chart
	Public Method New()			As Object
	Public Method Set3D()		As Object
	Public Method XmlPlot()
	Public Method XmlSer()
EndClass

/*/{Protheus.doc} ChartStock::New
Construtor do grßfico de ań§es
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@param oExcel, object, InstŌncia da classe custom.excel.Xlsx
@return object, self
@type method
/*/
Method New(oExcel As Object) as Object Class ChartStock
	_Super:New(oExcel)
	::cClassName	:= "CUSTOM.EXCEL.CHART.CHARTSTOCK"
Return self

/*/{Protheus.doc} ChartStock::Set3D
Ań§es nŃo possuem versŃo 3D no ECMA-376
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@return object, self
@type method
/*/
Method Set3D(lAtivo As Logical, nRotX As Numeric, nRotY As Numeric, nPerspectiva As Numeric) as Object Class ChartStock
	UserException(::cClassName+" - Este tipo de grßfico nŃo possui versŃo 3D no ECMA-376")
Return self

/*/{Protheus.doc} ChartStock::XmlPlot
Gera o c:stockChart e os eixos
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@return characters, XML do plotArea
@type method
/*/
Method XmlPlot() Class ChartStock
	Local cXml := "" As Character
	Local nCont As Numeric
	Local nQtd := Len(::aSeries) As Numeric
	If nQtd<3 .or. nQtd>4
		UserException("ChartStock - Informar 3 sķries na ordem (Mßxima,MĒnima,Fechamento) ou 4 (Abertura,Mßxima,MĒnima,Fechamento)")
	Endif
	cXml	+= '<c:stockChart>'
	For nCont:=1 to nQtd
		cXml	+= ::XmlSer(::aSeries[nCont],nCont-1)
	Next
	cXml	+= '<c:hiLowLines/>'	//Linhas de mßxima/mĒnima
	If nQtd==4
		//Barras de alta/baixa (abertura x fechamento)
		cXml	+= '<c:upDownBars>'
		cXml	+= '<c:gapWidth val="150"/>'
		cXml	+= '<c:upBars/>'
		cXml	+= '<c:downBars/>'
		cXml	+= '</c:upDownBars>'
	Endif
	cXml	+= '<c:axId val="'+cValToChar(::nIdEixo1)+'"/>'
	cXml	+= '<c:axId val="'+cValToChar(::nIdEixo2)+'"/>'
	cXml	+= '</c:stockChart>'
	cXml	+= ::XmlEixos("b","l")
Return cXml

/*/{Protheus.doc} ChartStock::XmlSer
Gera uma sķrie do grßfico de ań§es (linha invisĒvel; no HLC o fechamento recebe marcador)
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@param oSerie, object, Objeto Serie
@param nIdx, numeric, ═ndice da sķrie (base zero)
@return characters, XML da sķrie
@type method
/*/
Method XmlSer(oSerie As Object, nIdx As Numeric) Class ChartStock
	Local cXml := "" As Character
	cXml	+= XmlSerIni(oSerie,nIdx)
	cXml	+= '<c:spPr><a:ln><a:noFill/></a:ln></c:spPr>'	//Linha invisĒvel
	If Len(::aSeries)==3 .and. nIdx==2
		cXml	+= '<c:marker><c:symbol val="dot"/><c:size val="3"/></c:marker>'	//Fechamento no HLC
	Else
		cXml	+= '<c:marker><c:symbol val="none"/></c:marker>'
	Endif
	cXml	+= XmlCat(oSerie)
	cXml	+= XmlVal(oSerie)
	cXml	+= '<c:smooth val="0"/>'
	cXml	+= '</c:ser>'
Return cXml

