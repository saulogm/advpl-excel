//----------------------------------------------------------------------
/*/{Protheus.doc} ChartSurface
Grßfico de superfĒcie (c:surfaceChart / c:surface3DChart - ECMA-376 ¦21.2.2.204).
A versŃo 2D ķ a visŃo de contorno (vista de cima); com Set3D(.T.) gera a superfĒcie 3D.
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@type class
@see custom.excel.chart.Chart
@obs Requer no mĒnimo 2 sķries. Usa sempre 3 eixos (categorias, valores e sķries)
/*/
Class ChartSurface from Chart
	Public Data lWireframe		As Logical		//Somente estrutura de arame (sem preenchimento)

	Public Method New()				As Object
	Public Method SetWireframe()	As Object
	Public Method XmlPlot()
	Public Method XmlSer()
EndClass

/*/{Protheus.doc} ChartSurface::New
Construtor do grßfico de superfĒcie
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@param oExcel, object, InstŌncia da classe custom.excel.Xlsx
@return object, self
@type method
/*/
Method New(oExcel As Object) as Object Class ChartSurface
	_Super:New(oExcel)
	::cClassName	:= "CUSTOM.EXCEL.CHART.CHARTSURFACE"
	::lWireframe	:= .F.
Return self

/*/{Protheus.doc} ChartSurface::SetWireframe
Define a exibińŃo somente da estrutura de arame (sem preenchimento das bandas)
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@param lWireframe, logical, .T. exibe somente a estrutura
@return object, self
@type method
/*/
Method SetWireframe(lWireframe As Logical) as Object Class ChartSurface
	PARAMTYPE 0	VAR lWireframe	AS LOGICAL	OPTIONAL DEFAULT .T.
	::lWireframe	:= lWireframe
Return self

/*/{Protheus.doc} ChartSurface::XmlPlot
Gera o c:surfaceChart/c:surface3DChart e os trĻs eixos
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@return characters, XML do plotArea
@type method
/*/
Method XmlPlot() Class ChartSurface
	Local cXml := "" As Character
	Local nCont As Numeric
	Local cTag As Character
	If Len(::aSeries)<2
		UserException("ChartSurface - Informar no mĒnimo 2 sķries")
	Endif
	cTag	:= If(::l3D,"c:surface3DChart","c:surfaceChart")
	cXml	+= '<'+cTag+'>'
	cXml	+= '<c:wireframe val="'+If(::lWireframe,"1","0")+'"/>'
	For nCont:=1 to Len(::aSeries)
		cXml	+= ::XmlSer(::aSeries[nCont],nCont-1)
	Next
	cXml	+= '<c:axId val="'+cValToChar(::nIdEixo1)+'"/>'
	cXml	+= '<c:axId val="'+cValToChar(::nIdEixo2)+'"/>'
	cXml	+= '<c:axId val="'+cValToChar(::nIdEixo3)+'"/>'
	cXml	+= '</'+cTag+'>'
	//SuperfĒcie usa sempre 3 eixos, mesmo em 2D (contorno)
	cXml	+= ::XmlEixos("b","l")
	cXml	+= ::XmlEixoSer()
Return cXml

/*/{Protheus.doc} ChartSurface::XmlSer
Gera uma sķrie do grßfico de superfĒcie (c:ser - as cores das bandas sŃo automßticas)
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@param oSerie, object, Objeto Serie
@param nIdx, numeric, ═ndice da sķrie (base zero)
@return characters, XML da sķrie
@type method
/*/
Method XmlSer(oSerie As Object, nIdx As Numeric) Class ChartSurface
	Local cXml := "" As Character
	cXml	+= XmlSerIni(oSerie,nIdx)
	cXml	+= XmlCat(oSerie)
	cXml	+= XmlVal(oSerie)
	cXml	+= '</c:ser>'
Return cXml

//----------------------------------------------------------------------
//COMBINAŪ├O DE GR┴FICOS
//----------------------------------------------------------------------
/*/{Protheus.doc} ChartCombo
CombinańŃo de grßficos no mesmo plotArea (ex: barras + linhas).
Os grßficos membros (ChartBar, ChartLine, ChartArea) sŃo configurados normalmente
com suas sķries e adicionados pelo mķtodo :AddChart(), com opńŃo de eixo de valores
secundßrio (Ó direita). Quem insere na planilha ķ o combo (:Insert()).
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@type class
@see custom.excel.chart.Chart
@obs Os grßficos membros N├O devem chamar :Insert()
/*/
Class ChartCombo from Chart
	Public Data aCharts			As Array		//Grßficos membros {{oChart,lEixoSecundario}}
	Public Data nIdEixoSec1		As Numeric		//Id do eixo de categorias secundßrio (oculto)
	Public Data nIdEixoSec2		As Numeric		//Id do eixo de valores secundßrio (direita)

	Public Method New()			As Object
	Public Method AddChart()	As Object
	Public Method AddSerie()	As Object
	Public Method Set3D()		As Object
	Public Method ChecarSeries()
	Public Method XmlPlot()
	Public Method XmlEixosSec()
EndClass

/*/{Protheus.doc} ChartCombo::New
Construtor da combinańŃo de grßficos
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@param oExcel, object, InstŌncia da classe custom.excel.Xlsx
@return object, self
@type method
/*/
Method New(oExcel As Object) as Object Class ChartCombo
	_Super:New(oExcel)
	::cClassName	:= "CUSTOM.EXCEL.CHART.CHARTCOMBO"
	::aCharts		:= {}
	::nIdEixoSec1	:= 0
	::nIdEixoSec2	:= 0
Return self

/*/{Protheus.doc} ChartCombo::AddChart
Adiciona um grßfico membro Ó combinańŃo
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@param oChart, object, Grßfico membro (ChartBar, ChartLine ou ChartArea) jß com as sķries
@param lEixoSecundario, logical, .T. usa o eixo de valores secundßrio (direita)
@return object, O pr¾prio grßfico membro
@type method
/*/
Method AddChart(oChart As Object, lEixoSecundario As Logical) as Object Class ChartCombo
	Local cClasse As Character
	PARAMTYPE 0	VAR oChart			AS OBJECT
	PARAMTYPE 1	VAR lEixoSecundario	AS LOGICAL	OPTIONAL DEFAULT .F.
	cClasse	:= oChart:ClassName()
	If !(cClasse=="CUSTOM.EXCEL.CHART.CHARTBAR" .or. cClasse=="CUSTOM.EXCEL.CHART.CHARTLINE" .or. cClasse=="CUSTOM.EXCEL.CHART.CHARTAREA")
		UserException("ChartCombo - Somente ChartBar, ChartLine e ChartArea podem ser combinados ("+cClasse+")")
	Endif
	If oChart:l3D
		UserException("ChartCombo - Grßficos 3D nŃo podem ser combinados")
	Endif
	AADD(::aCharts,{oChart,lEixoSecundario})
Return oChart

/*/{Protheus.doc} ChartCombo::AddSerie
NŃo utilizado na combinańŃo - as sķries pertencem aos grßficos membros
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@return object, self
@type method
/*/
Method AddSerie(cNome As Character, cRefVal As Character, cRefCat As Character, aVal As Array, aCat As Array, cCor As Character) as Object Class ChartCombo
	UserException("ChartCombo - Adicionar as sķries nos grßficos membros e usar o mķtodo :AddChart()")
Return self

/*/{Protheus.doc} ChartCombo::Set3D
CombinańŃo nŃo suporta 3D
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@return object, self
@type method
/*/
Method Set3D(lAtivo As Logical, nRotX As Numeric, nRotY As Numeric, nPerspectiva As Numeric) as Object Class ChartCombo
	UserException(::cClassName+" - CombinańŃo de grßficos nŃo suporta 3D")
Return self

/*/{Protheus.doc} ChartCombo::ChecarSeries
Valida os grßficos membros antes da inserńŃo
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@type method
/*/
Method ChecarSeries() Class ChartCombo
	Local nCont As Numeric
	If Len(::aCharts)<2
		UserException("ChartCombo - Adicionar ao menos 2 grßficos com o mķtodo :AddChart()")
	Endif
	For nCont:=1 to Len(::aCharts)
		If Empty(::aCharts[nCont][1]:aSeries)
			UserException("ChartCombo - Grßfico membro "+cValToChar(nCont)+" sem sķries, usar :AddSerie() no membro")
		Endif
		If ::aCharts[nCont][1]:l3D
			UserException("ChartCombo - Grßficos 3D nŃo podem ser combinados")
		Endif
	Next
Return

/*/{Protheus.doc} ChartCombo::XmlPlot
Gera os grupos dos grßficos membros compartilhando os eixos e, quando houver
membro no eixo secundßrio, o par de eixos secundßrio
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@return characters, XML do plotArea
@type method
/*/
Method XmlPlot() Class ChartCombo
	Local cXml := "" As Character
	Local nCont As Numeric
	Local nIdxAcum := 0 As Numeric
	Local lTemSec := .F. As Logical
	Local oChart As Object
	//Ids do par de eixos secundßrio deste grßfico
	::nIdEixoSec1	:= 100000004+(::nChart*10)
	::nIdEixoSec2	:= 100000005+(::nChart*10)
	For nCont:=1 to Len(::aCharts)
		oChart	:= ::aCharts[nCont][1]
		If ::aCharts[nCont][2]	//Membro no eixo secundßrio
			lTemSec	:= .T.
			oChart:nIdEixo1	:= ::nIdEixoSec1
			oChart:nIdEixo2	:= ::nIdEixoSec2
		Else	//Membro no eixo primßrio
			oChart:nIdEixo1	:= ::nIdEixo1
			oChart:nIdEixo2	:= ::nIdEixo2
		Endif
		//idx/order das sķries devem ser ·nicos no plotArea inteiro
		cXml	+= oChart:XmlGrupo(nIdxAcum)
		nIdxAcum	+= Len(oChart:aSeries)
	Next
	cXml	+= ::XmlEixos("b","l")
	If lTemSec
		cXml	+= ::XmlEixosSec()
	Endif
Return cXml

/*/{Protheus.doc} ChartCombo::XmlEixosSec
Gera o par de eixos secundßrio: valores Ó direita e categorias oculto
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@return characters, XML dos eixos secundßrios
@type method
/*/
Method XmlEixosSec() Class ChartCombo
	Local cXml := "" As Character
	//Eixo de valores secundßrio (direita)
	cXml	+= '<c:valAx>'
	cXml	+= '<c:axId val="'+cValToChar(::nIdEixoSec2)+'"/>'
	cXml	+= '<c:scaling><c:orientation val="minMax"/></c:scaling>'
	cXml	+= '<c:delete val="0"/>'
	cXml	+= '<c:axPos val="r"/>'
	cXml	+= '<c:numFmt formatCode="General" sourceLinked="1"/>'
	cXml	+= '<c:tickLblPos val="nextTo"/>'
	cXml	+= '<c:crossAx val="'+cValToChar(::nIdEixoSec1)+'"/>'
	cXml	+= '<c:crosses val="max"/>'
	cXml	+= '<c:crossBetween val="between"/>'
	cXml	+= '</c:valAx>'
	//Eixo de categorias secundßrio (oculto)
	cXml	+= '<c:catAx>'
	cXml	+= '<c:axId val="'+cValToChar(::nIdEixoSec1)+'"/>'
	cXml	+= '<c:scaling><c:orientation val="minMax"/></c:scaling>'
	cXml	+= '<c:delete val="1"/>'
	cXml	+= '<c:axPos val="b"/>'
	cXml	+= '<c:tickLblPos val="nextTo"/>'
	cXml	+= '<c:crossAx val="'+cValToChar(::nIdEixoSec2)+'"/>'
	cXml	+= '<c:crosses val="autoZero"/>'
	cXml	+= '<c:auto val="1"/>'
	cXml	+= '<c:lblAlgn val="ctr"/>'
	cXml	+= '<c:lblOffset val="100"/>'
	cXml	+= '<c:noMultiLvlLbl val="0"/>'
	cXml	+= '</c:catAx>'
Return cXml

//----------------------------------------------------------------------
//FUNŪšES AUXILIARES (estßticas do fonte)
//----------------------------------------------------------------------
/*/{Protheus.doc} XmlSerIni
Gera a abertura da sķrie (c:ser com c:idx, c:order e c:tx)
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@param oSerie, object, Objeto Serie
@param nIdx, numeric, ═ndice da sķrie (base zero)
@return characters, XML de abertura da sķrie (sem fechar o c:ser)
@type function
/*/
Static Function XmlSerIni(oSerie As Object, nIdx As Numeric)
	Local cXml := "" As Character
	cXml	+= '<c:ser>'
	cXml	+= '<c:idx val="'+cValToChar(nIdx)+'"/>'
	cXml	+= '<c:order val="'+cValToChar(nIdx)+'"/>'
	If !Empty(oSerie:cNome)
		If "!" $ oSerie:cNome	//Nome por referĻncia de cķlula (ex: "Dados!$B$1")
			cXml	+= '<c:tx>'+XmlStr(oSerie:cNome,{})+'</c:tx>'
		Else	//Nome literal
			cXml	+= '<c:tx><c:v>'+EscXml(oSerie:cNome)+'</c:v></c:tx>'
		Endif
	Endif
Return cXml

/*/{Protheus.doc} XmlCat
Gera as categorias da sķrie (c:cat)
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@param oSerie, object, Objeto Serie
@return characters, XML das categorias (vazio se nŃo informadas)
@type function
/*/
Static Function XmlCat(oSerie As Object)
	Local cXml := "" As Character
	If !Empty(oSerie:cRefCat) .or. !Empty(oSerie:aCat)
		cXml	+= '<c:cat>'+XmlStr(oSerie:cRefCat,oSerie:aCat)+'</c:cat>'
	Endif
Return cXml

/*/{Protheus.doc} XmlVal
Gera os valores da sķrie (c:val)
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@param oSerie, object, Objeto Serie
@return characters, XML dos valores
@type function
/*/
Static Function XmlVal(oSerie As Object)
	Local cXml := "" As Character
	If Empty(oSerie:cRefVal) .and. Empty(oSerie:aVal)
		UserException("Chart - Sķrie sem valores, informar cRefVal ou aVal no :AddSerie()")
	Endif
	cXml	+= '<c:val>'+XmlNum(oSerie:cRefVal,oSerie:aVal)+'</c:val>'
Return cXml

/*/{Protheus.doc} XmlStr
Gera referĻncia de texto (c:strRef com c:strCache) ou literal (c:strLit)
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@param cRef, characters, ReferĻncia de cķlulas (opcional)
@param aValores, array, Valores literais (opcional, gera cache)
@return characters, XML da referĻncia
@type function
/*/
Static Function XmlStr(cRef As Character, aValores As Array)
	Local cXml := "" As Character
	Local nCont As Numeric
	Default cRef		:= ""
	Default aValores	:= {}
	If !Empty(cRef)
		cXml	+= '<c:strRef>'
		cXml	+= '<c:f>'+EscXml(cRef)+'</c:f>'
		If !Empty(aValores)	//Cache opcional dos valores
			cXml	+= '<c:strCache>'
			cXml	+= '<c:ptCount val="'+cValToChar(Len(aValores))+'"/>'
			For nCont:=1 to Len(aValores)
				cXml	+= '<c:pt idx="'+cValToChar(nCont-1)+'"><c:v>'+EscXml(aValores[nCont])+'</c:v></c:pt>'
			Next
			cXml	+= '</c:strCache>'
		Endif
		cXml	+= '</c:strRef>'
	Else	//Somente valores literais
		cXml	+= '<c:strLit>'
		cXml	+= '<c:ptCount val="'+cValToChar(Len(aValores))+'"/>'
		For nCont:=1 to Len(aValores)
			cXml	+= '<c:pt idx="'+cValToChar(nCont-1)+'"><c:v>'+EscXml(aValores[nCont])+'</c:v></c:pt>'
		Next
		cXml	+= '</c:strLit>'
	Endif
Return cXml

/*/{Protheus.doc} XmlNum
Gera referĻncia numķrica (c:numRef com c:numCache) ou literal (c:numLit)
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@param cRef, characters, ReferĻncia de cķlulas (opcional)
@param aValores, array, Valores literais (opcional, gera cache)
@return characters, XML da referĻncia
@type function
/*/
Static Function XmlNum(cRef As Character, aValores As Array)
	Local cXml := "" As Character
	Local nCont As Numeric
	Default cRef		:= ""
	Default aValores	:= {}
	If !Empty(cRef)
		cXml	+= '<c:numRef>'
		cXml	+= '<c:f>'+EscXml(cRef)+'</c:f>'
		If !Empty(aValores)	//Cache opcional dos valores
			cXml	+= '<c:numCache>'
			cXml	+= '<c:formatCode>General</c:formatCode>'
			cXml	+= '<c:ptCount val="'+cValToChar(Len(aValores))+'"/>'
			For nCont:=1 to Len(aValores)
				cXml	+= '<c:pt idx="'+cValToChar(nCont-1)+'"><c:v>'+EscXml(aValores[nCont])+'</c:v></c:pt>'
			Next
			cXml	+= '</c:numCache>'
		Endif
		cXml	+= '</c:numRef>'
	Else	//Somente valores literais
		cXml	+= '<c:numLit>'
		cXml	+= '<c:ptCount val="'+cValToChar(Len(aValores))+'"/>'
		For nCont:=1 to Len(aValores)
			cXml	+= '<c:pt idx="'+cValToChar(nCont-1)+'"><c:v>'+EscXml(aValores[nCont])+'</c:v></c:pt>'
		Next
		cXml	+= '</c:numLit>'
	Endif
Return cXml

/*/{Protheus.doc} XmlCor
Gera preenchimento s¾lido com a cor informada (a:solidFill)
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@param cCor, characters, Cor RGB (6 dĒgitos) ou ARGB (8 dĒgitos, o alfa ķ descartado)
@return characters, XML do preenchimento
@type function
/*/
Static Function XmlCor(cCor As Character)
	cCor	:= UPPER(AllTrim(cCor))
	If Len(cCor)==8	//ARGB usado pela classe Xlsx, remove o canal alfa
		cCor	:= SubStr(cCor,3)
	Endif
Return '<a:solidFill><a:srgbClr val="'+cCor+'"/></a:solidFill>'

/*/{Protheus.doc} EscXml
Escapa os caracteres reservados do XML e converte o texto para UTF-8
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@param xTexto, variadic, Texto ou valor a ser escapado
@return characters, Texto seguro para uso no XML
@type function
/*/
Static Function EscXml(xTexto As Variant)
	Local cTexto As Character
	Local cUtf8 As Character
	If ValType(xTexto)=="C"
		cTexto	:= xTexto
	Else
		cTexto	:= cValToChar(xTexto)
	Endif
	cTexto	:= StrTran(cTexto,"&","&amp;")
	cTexto	:= StrTran(cTexto,"<","&lt;")
	cTexto	:= StrTran(cTexto,">","&gt;")
	cTexto	:= StrTran(cTexto,'"',"&quot;")
	cTexto	:= StrTran(cTexto,"'","&apos;")
	cUtf8	:= EncodeUTF8(cTexto)	//O XML das partes ķ gravado em UTF-8
	If ValType(cUtf8)=="C"
		cTexto	:= cUtf8
	Endif
Return cTexto

/*/{Protheus.doc} AjustNs
Ajusta o prefixo de namespace dos nodes criados pelo TXmlManager
(mesma tķcnica da funńŃo ajustNS do fonte custom.excel.tlpp) e
registra novamente os namespaces para as consultas XPath
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@param oXml, object, TXmlManager do drawing
@param cDe, characters, Texto a ser substituĒdo (ex: "<xdr:a:")
@param cPara, characters, Texto substituto (ex: "<a:")
@type function
/*/
Static Function AjustNs(oXml As Object, cDe As Character, cPara As Character)
	Local aNs As Array
	Local nCont As Numeric
	oXml:Parse(Replace(oXml:Save2String(),cDe,cPara))
	aNs	:= oXml:XPathGetRootNsList()
	For nCont:=1 to Len(aNs)
		oXml:XPathRegisterNs( aNs[nCont][1], aNs[nCont][2] )
	Next
	//Prefixos usados pelo grßfico que nŃo estŃo declarados na raiz do drawing
	oXml:XPathRegisterNs( "c", NS_CHART )
	oXml:XPathRegisterNs( "r", NS_REL )
Return
