/*/{Protheus.doc} ChartOfPie
Grßfico de pizza de pizza ou barra de pizza (c:ofPieChart - ECMA-376 ¦21.2.2.126).
As ·ltimas fatias sŃo destacadas em um segundo grßfico (pizza ou barra).
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@type class
@see custom.excel.chart.ChartPie
/*/
Class ChartOfPie from ChartPie
	Public Data cTipoSec		As Character	//Tipo do grßfico secundßrio: pie=pizza, bar=barra
	Public Data cDivisao		As Character	//Critķrio de divisŃo: auto, pos, val, percent
	Public Data nDivisao		As Numeric		//Valor da divisŃo (posińŃo/valor/percentual)
	Public Data nTamSec			As Numeric		//Tamanho do grßfico secundßrio em % (c:secondPieSize)
	Public Data nGapWidth		As Numeric		//Espańo entre os dois grßficos (%)

	Public Method New()			As Object
	Public Method SetTipo()		As Object
	Public Method SetDivisao()	As Object
	Public Method Set3D()		As Object
	Public Method XmlPlot()
EndClass

/*/{Protheus.doc} ChartOfPie::New
Construtor do grßfico de pizza de pizza
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@param oExcel, object, InstŌncia da classe custom.excel.Xlsx
@return object, self
@type method
/*/
Method New(oExcel As Object) as Object Class ChartOfPie
	_Super:New(oExcel)
	::cClassName	:= "CUSTOM.EXCEL.CHART.CHARTOFPIE"
	::cTipoSec		:= "pie"
	::cDivisao		:= "auto"
	::nDivisao		:= 0
	::nTamSec		:= 75
	::nGapWidth		:= 100
Return self

/*/{Protheus.doc} ChartOfPie::SetTipo
Define o tipo do grßfico secundßrio
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@param cTipo, characters, pie=pizza de pizza, bar=barra de pizza
@return object, self
@type method
/*/
Method SetTipo(cTipo As Character) as Object Class ChartOfPie
	PARAMTYPE 0	VAR cTipo		AS CHARACTER
	cTipo	:= lower(AllTrim(cTipo))
	If !(cTipo=="pie" .or. cTipo=="bar")
		UserException("ChartOfPie - Tipo invßlido ("+cTipo+"). Usar: pie,bar")
	Endif
	::cTipoSec	:= cTipo
Return self

/*/{Protheus.doc} ChartOfPie::SetDivisao
Define o critķrio de divisŃo das fatias para o grßfico secundßrio
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@param cTipo, characters, auto=automßtico, pos=·ltimas N fatias, val=valores menores que N, percent=percentuais menores que N
@param nValor, numeric, Valor do critķrio (quando nŃo automßtico)
@return object, self
@type method
/*/
Method SetDivisao(cTipo As Character, nValor As Numeric) as Object Class ChartOfPie
	PARAMTYPE 0	VAR cTipo		AS CHARACTER
	PARAMTYPE 1	VAR nValor		AS NUMERIC	OPTIONAL DEFAULT 0
	If !(cTipo=="auto" .or. cTipo=="pos" .or. cTipo=="val" .or. cTipo=="percent")
		UserException("ChartOfPie - DivisŃo invßlida ("+cTipo+"). Usar: auto,pos,val,percent")
	Endif
	If cTipo!="auto" .and. nValor<=0
		UserException("ChartOfPie - Informar o valor da divisŃo (nValor)")
	Endif
	::cDivisao	:= cTipo
	::nDivisao	:= nValor
Return self

/*/{Protheus.doc} ChartOfPie::Set3D
Pizza de pizza nŃo possui versŃo 3D no ECMA-376
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@return object, self
@type method
/*/
Method Set3D(lAtivo As Logical, nRotX As Numeric, nRotY As Numeric, nPerspectiva As Numeric) as Object Class ChartOfPie
	UserException(::cClassName+" - Este tipo de grßfico nŃo possui versŃo 3D no ECMA-376")
Return self

/*/{Protheus.doc} ChartOfPie::XmlPlot
Gera o c:ofPieChart (sem eixos)
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@return characters, XML do plotArea
@type method
/*/
Method XmlPlot() Class ChartOfPie
	Local cXml := "" As Character
	Local nCont As Numeric
	cXml	+= '<c:ofPieChart>'
	cXml	+= '<c:ofPieType val="'+::cTipoSec+'"/>'
	cXml	+= '<c:varyColors val="1"/>'
	For nCont:=1 to Len(::aSeries)
		cXml	+= ::XmlSer(::aSeries[nCont],nCont-1)
	Next
	cXml	+= ::XmlRotulos()
	cXml	+= '<c:gapWidth val="'+cValToChar(::nGapWidth)+'"/>'
	If ::cDivisao!="auto"
		cXml	+= '<c:splitType val="'+::cDivisao+'"/>'
		cXml	+= '<c:splitPos val="'+cValToChar(::nDivisao)+'"/>'
	Endif
	cXml	+= '<c:secondPieSize val="'+cValToChar(::nTamSec)+'"/>'
	cXml	+= '<c:serLines/>'	//Linhas ligando os dois grßficos
	cXml	+= '</c:ofPieChart>'
Return cXml

