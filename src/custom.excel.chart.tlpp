/*/{Protheus.doc} ChartDoughnut
Gráfico de rosca (c:doughnutChart - ECMA-376 §21.2.2.50)
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@type class
@see custom.excel.chart.ChartPie
@obs Herda séries, rótulos e ângulo inicial do ChartPie
/*/
Class ChartDoughnut from ChartPie
	Public Data nFuro			As Numeric		//Tamanho do furo central em % (c:holeSize)

	Public Method New()			As Object
	Public Method SetFuro()		As Object
	Public Method Set3D()		As Object
	Public Method XmlPlot()
EndClass

/*/{Protheus.doc} ChartDoughnut::New
Construtor do gráfico de rosca
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@param oExcel, object, Instância da classe custom.excel.Xlsx
@return object, self
@type method
/*/
Method New(oExcel As Object) as Object Class ChartDoughnut
	_Super:New(oExcel)
	::cClassName	:= "CUSTOM.EXCEL.CHART.CHARTDOUGHNUT"
	::nFuro			:= 50
Return self

/*/{Protheus.doc} ChartDoughnut::SetFuro
Define o tamanho do furo central da rosca
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@param nFuro, numeric, Percentual do furo (10 a 90)
@return object, self
@type method
/*/
Method SetFuro(nFuro As Numeric) as Object Class ChartDoughnut
	PARAMTYPE 0	VAR nFuro		AS NUMERIC
	If nFuro<10 .or. nFuro>90
		UserException("ChartDoughnut - Furo inválido ("+cValToChar(nFuro)+"). Usar entre 10 e 90")
	Endif
	::nFuro	:= nFuro
Return self

/*/{Protheus.doc} ChartDoughnut::Set3D
Rosca não possui versão 3D no ECMA-376
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@return object, self
@type method
/*/
Method Set3D(lAtivo As Logical, nRotX As Numeric, nRotY As Numeric, nPerspectiva As Numeric) as Object Class ChartDoughnut
	UserException(::cClassName+" - Este tipo de gráfico não possui versão 3D no ECMA-376")
Return self

/*/{Protheus.doc} ChartDoughnut::XmlPlot
Gera o c:doughnutChart (sem eixos)
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@return characters, XML do plotArea
@type method
/*/
Method XmlPlot() Class ChartDoughnut
	Local cXml := "" As Character
	Local nCont As Numeric
	cXml	+= '<c:doughnutChart>'
	cXml	+= '<c:varyColors val="1"/>'	//Uma cor por fatia
	For nCont:=1 to Len(::aSeries)
		cXml	+= ::XmlSer(::aSeries[nCont],nCont-1)
	Next
	cXml	+= ::XmlRotulos()
	cXml	+= '<c:firstSliceAng val="'+cValToChar(::nAnguloIni)+'"/>'
	cXml	+= '<c:holeSize val="'+cValToChar(::nFuro)+'"/>'
	cXml	+= '</c:doughnutChart>'
Return cXml

//----------------------------------------------------------------------
//GRÁFICO DE PIZZA DE PIZZA / BARRA DE PIZZA
//----------------------------------------------------------------------
/*/{Protheus.doc} ChartOfPie
Gráfico de pizza de pizza ou barra de pizza (c:ofPieChart - ECMA-376 §21.2.2.126).
As últimas fatias são destacadas em um segundo gráfico (pizza ou barra).
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@type class
@see custom.excel.chart.ChartPie
/*/
Class ChartOfPie from ChartPie
	Public Data cTipoSec		As Character	//Tipo do gráfico secundário: pie=pizza, bar=barra
	Public Data cDivisao		As Character	//Critério de divisão: auto, pos, val, percent
	Public Data nDivisao		As Numeric		//Valor da divisão (posição/valor/percentual)
	Public Data nTamSec			As Numeric		//Tamanho do gráfico secundário em % (c:secondPieSize)
	Public Data nGapWidth		As Numeric		//Espaço entre os dois gráficos (%)

	Public Method New()			As Object
	Public Method SetTipo()		As Object
	Public Method SetDivisao()	As Object
	Public Method Set3D()		As Object
	Public Method XmlPlot()
EndClass

/*/{Protheus.doc} ChartOfPie::New
Construtor do gráfico de pizza de pizza
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@param oExcel, object, Instância da classe custom.excel.Xlsx
@return object, self
@type method
/*/
Method New(oExcel As Object) as Object Class ChartOfPie
	_Super:New(oExcel)
	::cClassName	:= "CUSTOM.EXCEL.CHART.CHARTOFPIE"
	::cTipoSec		:= "pie"
	::cDivisao		:= "auto"
	::nDivisao		:= 0
	::nTamSec		:= 75
	::nGapWidth		:= 100
Return self

/*/{Protheus.doc} ChartOfPie::SetTipo
Define o tipo do gráfico secundário
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@param cTipo, characters, pie=pizza de pizza, bar=barra de pizza
@return object, self
@type method
/*/
Method SetTipo(cTipo As Character) as Object Class ChartOfPie
	PARAMTYPE 0	VAR cTipo		AS CHARACTER
	cTipo	:= lower(AllTrim(cTipo))
	If !(cTipo=="pie" .or. cTipo=="bar")
		UserException("ChartOfPie - Tipo inválido ("+cTipo+"). Usar: pie,bar")
	Endif
	::cTipoSec	:= cTipo
Return self

/*/{Protheus.doc} ChartOfPie::SetDivisao
Define o critério de divisão das fatias para o gráfico secundário
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@param cTipo, characters, auto=automático, pos=últimas N fatias, val=valores menores que N, percent=percentuais menores que N
@param nValor, numeric, Valor do critério (quando não automático)
@return object, self
@type method
/*/
Method SetDivisao(cTipo As Character, nValor As Numeric) as Object Class ChartOfPie
	PARAMTYPE 0	VAR cTipo		AS CHARACTER
	PARAMTYPE 1	VAR nValor		AS NUMERIC	OPTIONAL DEFAULT 0
	If !(cTipo=="auto" .or. cTipo=="pos" .or. cTipo=="val" .or. cTipo=="percent")
		UserException("ChartOfPie - Divisão inválida ("+cTipo+"). Usar: auto,pos,val,percent")
	Endif
	If cTipo!="auto" .and. nValor<=0
		UserException("ChartOfPie - Informar o valor da divisão (nValor)")
	Endif
	::cDivisao	:= cTipo
	::nDivisao	:= nValor
Return self

/*/{Protheus.doc} ChartOfPie::Set3D
Pizza de pizza não possui versão 3D no ECMA-376
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@return object, self
@type method
/*/
Method Set3D(lAtivo As Logical, nRotX As Numeric, nRotY As Numeric, nPerspectiva As Numeric) as Object Class ChartOfPie
	UserException(::cClassName+" - Este tipo de gráfico não possui versão 3D no ECMA-376")
Return self

/*/{Protheus.doc} ChartOfPie::XmlPlot
Gera o c:ofPieChart (sem eixos)
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@return characters, XML do plotArea
@type method
/*/
Method XmlPlot() Class ChartOfPie
	Local cXml := "" As Character
	Local nCont As Numeric
	cXml	+= '<c:ofPieChart>'
	cXml	+= '<c:ofPieType val="'+::cTipoSec+'"/>'
	cXml	+= '<c:varyColors val="1"/>'
	For nCont:=1 to Len(::aSeries)
		cXml	+= ::XmlSer(::aSeries[nCont],nCont-1)
	Next
	cXml	+= ::XmlRotulos()
	cXml	+= '<c:gapWidth val="'+cValToChar(::nGapWidth)+'"/>'
	If ::cDivisao!="auto"
		cXml	+= '<c:splitType val="'+::cDivisao+'"/>'
		cXml	+= '<c:splitPos val="'+cValToChar(::nDivisao)+'"/>'
	Endif
	cXml	+= '<c:secondPieSize val="'+cValToChar(::nTamSec)+'"/>'
	cXml	+= '<c:serLines/>'	//Linhas ligando os dois gráficos
	cXml	+= '</c:ofPieChart>'
Return cXml

