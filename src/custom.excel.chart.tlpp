/*/{Protheus.doc} ChartBubble
Gráfico de bolhas (c:bubbleChart - ECMA-376 §21.2.2.20).
Cada ponto possui X, Y e tamanho da bolha (c:bubbleSize).
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@type class
@see custom.excel.chart.ChartScatter
@obs Informar o tamanho das bolhas pelo método :SetTamanho() da série
/*/
Class ChartBubble from ChartScatter
	Public Data nEscala			As Numeric		//Escala do tamanho das bolhas em % (c:bubbleScale)
	Public Data cTamRepr		As Character	//O tamanho representa: area=área, w=largura (c:sizeRepresents)

	Public Method New()			As Object
	Public Method SetEscala()	As Object
	Public Method SetTamRepr()	As Object
	Public Method XmlPlot()
	Public Method XmlSer()
EndClass

/*/{Protheus.doc} ChartBubble::New
Construtor do gráfico de bolhas
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@param oExcel, object, Instância da classe custom.excel.Xlsx
@return object, self
@type method
/*/
Method New(oExcel As Object) as Object Class ChartBubble
	_Super:New(oExcel)
	::cClassName	:= "CUSTOM.EXCEL.CHART.CHARTBUBBLE"
	::nEscala		:= 100
	::cTamRepr		:= "area"
Return self

/*/{Protheus.doc} ChartBubble::SetEscala
Define a escala do tamanho das bolhas
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@param nEscala, numeric, Percentual da escala (0 a 300)
@return object, self
@type method
/*/
Method SetEscala(nEscala As Numeric) as Object Class ChartBubble
	PARAMTYPE 0	VAR nEscala		AS NUMERIC
	If nEscala<0 .or. nEscala>300
		UserException("ChartBubble - Escala inválida ("+cValToChar(nEscala)+"). Usar entre 0 e 300")
	Endif
	::nEscala	:= nEscala
Return self

/*/{Protheus.doc} ChartBubble::SetTamRepr
Define o que o valor do tamanho representa na bolha
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@param cTamRepr, characters, area=área da bolha, w=largura (diâmetro) da bolha
@return object, self
@type method
/*/
Method SetTamRepr(cTamRepr As Character) as Object Class ChartBubble
	PARAMTYPE 0	VAR cTamRepr	AS CHARACTER
	If !(cTamRepr=="area" .or. cTamRepr=="w")
		UserException("ChartBubble - Representação inválida ("+cTamRepr+"). Usar: area,w")
	Endif
	::cTamRepr	:= cTamRepr
Return self

/*/{Protheus.doc} ChartBubble::XmlPlot
Gera o c:bubbleChart e os dois eixos de valores
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@return characters, XML do plotArea
@type method
/*/
Method XmlPlot() Class ChartBubble
	Local cXml := "" As Character
	Local nCont As Numeric
	cXml	+= '<c:bubbleChart>'
	cXml	+= '<c:varyColors val="0"/>'
	For nCont:=1 to Len(::aSeries)
		cXml	+= ::XmlSer(::aSeries[nCont],nCont-1)
	Next
	cXml	+= '<c:bubbleScale val="'+cValToChar(::nEscala)+'"/>'
	cXml	+= '<c:showNegBubbles val="0"/>'
	cXml	+= '<c:sizeRepresents val="'+::cTamRepr+'"/>'
	cXml	+= '<c:axId val="'+cValToChar(::nIdEixo1)+'"/>'
	cXml	+= '<c:axId val="'+cValToChar(::nIdEixo2)+'"/>'
	cXml	+= '</c:bubbleChart>'
	cXml	+= ::XmlEixosVal()	//Dois eixos de valores herdados do ChartScatter
Return cXml

/*/{Protheus.doc} ChartBubble::XmlSer
Gera uma série do gráfico de bolhas (c:ser com c:xVal/c:yVal/c:bubbleSize)
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@param oSerie, object, Objeto Serie
@param nIdx, numeric, Índice da série (base zero)
@return characters, XML da série
@type method
/*/
Method XmlSer(oSerie As Object, nIdx As Numeric) Class ChartBubble
	Local cXml := "" As Character
	Local cRefX As Character
	Local cRefY As Character
	Local aX As Array
	Local aY As Array
	//X/Y podem ser informados via SetXY ou reaproveitando cRefCat/cRefVal do AddSerie
	cRefX	:= If(!Empty(oSerie:cRefX),oSerie:cRefX,oSerie:cRefCat)
	cRefY	:= If(!Empty(oSerie:cRefY),oSerie:cRefY,oSerie:cRefVal)
	aX		:= If(!Empty(oSerie:aX),oSerie:aX,oSerie:aCat)
	aY		:= If(!Empty(oSerie:aY),oSerie:aY,oSerie:aVal)
	If Empty(oSerie:cRefTam) .and. Empty(oSerie:aTam)
		UserException("ChartBubble - Série sem tamanho das bolhas, usar o método :SetTamanho() da série")
	Endif
	cXml	+= XmlSerIni(oSerie,nIdx)
	If !Empty(oSerie:cCor)
		cXml	+= '<c:spPr>'+XmlCor(oSerie:cCor)+'</c:spPr>'
	Endif
	cXml	+= '<c:xVal>'+XmlNum(cRefX,aX)+'</c:xVal>'
	cXml	+= '<c:yVal>'+XmlNum(cRefY,aY)+'</c:yVal>'
	cXml	+= '<c:bubbleSize>'+XmlNum(oSerie:cRefTam,oSerie:aTam)+'</c:bubbleSize>'
	cXml	+= '<c:bubble3D val="0"/>'
	cXml	+= '</c:ser>'
Return cXml

//----------------------------------------------------------------------
//GRÁFICO DE SUPERFÍCIE
//----------------------------------------------------------------------
/*/{Protheus.doc} ChartSurface
Gráfico de superfície (c:surfaceChart / c:surface3DChart - ECMA-376 §21.2.2.204).
A versão 2D é a visão de contorno (vista de cima); com Set3D(.T.) gera a superfície 3D.
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@type class
@see custom.excel.chart.Chart
@obs Requer no mínimo 2 séries. Usa sempre 3 eixos (categorias, valores e séries)
/*/
Class ChartSurface from Chart
	Public Data lWireframe		As Logical		//Somente estrutura de arame (sem preenchimento)

	Public Method New()				As Object
	Public Method SetWireframe()	As Object
	Public Method XmlPlot()
	Public Method XmlSer()
EndClass

/*/{Protheus.doc} ChartSurface::New
Construtor do gráfico de superfície
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@param oExcel, object, Instância da classe custom.excel.Xlsx
@return object, self
@type method
/*/
Method New(oExcel As Object) as Object Class ChartSurface
	_Super:New(oExcel)
	::cClassName	:= "CUSTOM.EXCEL.CHART.CHARTSURFACE"
	::lWireframe	:= .F.
Return self

/*/{Protheus.doc} ChartSurface::SetWireframe
Define a exibição somente da estrutura de arame (sem preenchimento das bandas)
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@param lWireframe, logical, .T. exibe somente a estrutura
@return object, self
@type method
/*/
Method SetWireframe(lWireframe As Logical) as Object Class ChartSurface
	PARAMTYPE 0	VAR lWireframe	AS LOGICAL	OPTIONAL DEFAULT .T.
	::lWireframe	:= lWireframe
Return self

/*/{Protheus.doc} ChartSurface::XmlPlot
Gera o c:surfaceChart/c:surface3DChart e os três eixos
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@return characters, XML do plotArea
@type method
/*/
Method XmlPlot() Class ChartSurface
	Local cXml := "" As Character
	Local nCont As Numeric
	Local cTag As Character
	If Len(::aSeries)<2
		UserException("ChartSurface - Informar no mínimo 2 séries")
	Endif
	cTag	:= If(::l3D,"c:surface3DChart","c:surfaceChart")
	cXml	+= '<'+cTag+'>'
	cXml	+= '<c:wireframe val="'+If(::lWireframe,"1","0")+'"/>'
	For nCont:=1 to Len(::aSeries)
		cXml	+= ::XmlSer(::aSeries[nCont],nCont-1)
	Next
	cXml	+= '<c:axId val="'+cValToChar(::nIdEixo1)+'"/>'
	cXml	+= '<c:axId val="'+cValToChar(::nIdEixo2)+'"/>'
	cXml	+= '<c:axId val="'+cValToChar(::nIdEixo3)+'"/>'
	cXml	+= '</'+cTag+'>'
	//Superfície usa sempre 3 eixos, mesmo em 2D (contorno)
	cXml	+= ::XmlEixos("b","l")
	cXml	+= ::XmlEixoSer()
Return cXml

/*/{Protheus.doc} ChartSurface::XmlSer
Gera uma série do gráfico de superfície (c:ser - as cores das bandas são automáticas)
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@param oSerie, object, Objeto Serie
@param nIdx, numeric, Índice da série (base zero)
@return characters, XML da série
@type method
/*/
Method XmlSer(oSerie As Object, nIdx As Numeric) Class ChartSurface
	Local cXml := "" As Character
	cXml	+= XmlSerIni(oSerie,nIdx)
	cXml	+= XmlCat(oSerie)
	cXml	+= XmlVal(oSerie)
	cXml	+= '</c:ser>'
Return cXml

//----------------------------------------------------------------------
//COMBINAÇÃO DE GRÁFICOS
//----------------------------------------------------------------------
/*/{Protheus.doc} ChartCombo
Combinação de gráficos no mesmo plotArea (ex: barras + linhas).
Os gráficos membros (ChartBar, ChartLine, ChartArea) são configurados normalmente
com suas séries e adicionados pelo método :AddChart(), com opção de eixo de valores
secundário (à direita). Quem insere na planilha é o combo (:Insert()).
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@type class
@see custom.excel.chart.Chart
@obs Os gráficos membros NÃO devem chamar :Insert()
/*/
Class ChartCombo from Chart
	Public Data aCharts			As Array		//Gráficos membros {{oChart,lEixoSecundario}}
	Public Data nIdEixoSec1		As Numeric		//Id do eixo de categorias secundário (oculto)
	Public Data nIdEixoSec2		As Numeric		//Id do eixo de valores secundário (direita)

	Public Method New()			As Object
	Public Method AddChart()	As Object
	Public Method AddSerie()	As Object
	Public Method Set3D()		As Object
	Public Method ChecarSeries()
	Public Method XmlPlot()
	Public Method XmlEixosSec()
EndClass

/*/{Protheus.doc} ChartCombo::New
Construtor da combinação de gráficos
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@param oExcel, object, Instância da classe custom.excel.Xlsx
@return object, self
@type method
/*/
Method New(oExcel As Object) as Object Class ChartCombo
	_Super:New(oExcel)
	::cClassName	:= "CUSTOM.EXCEL.CHART.CHARTCOMBO"
	::aCharts		:= {}
	::nIdEixoSec1	:= 0
	::nIdEixoSec2	:= 0
Return self

/*/{Protheus.doc} ChartCombo::AddChart
Adiciona um gráfico membro à combinação
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@param oChart, object, Gráfico membro (ChartBar, ChartLine ou ChartArea) já com as séries
@param lEixoSecundario, logical, .T. usa o eixo de valores secundário (direita)
@return object, O próprio gráfico membro
@type method
/*/
Method AddChart(oChart As Object, lEixoSecundario As Logical) as Object Class ChartCombo
	Local cClasse As Character
	PARAMTYPE 0	VAR oChart			AS OBJECT
	PARAMTYPE 1	VAR lEixoSecundario	AS LOGICAL	OPTIONAL DEFAULT .F.
	cClasse	:= oChart:ClassName()
	If !(cClasse=="CUSTOM.EXCEL.CHART.CHARTBAR" .or. cClasse=="CUSTOM.EXCEL.CHART.CHARTLINE" .or. cClasse=="CUSTOM.EXCEL.CHART.CHARTAREA")
		UserException("ChartCombo - Somente ChartBar, ChartLine e ChartArea podem ser combinados ("+cClasse+")")
	Endif
	If oChart:l3D
		UserException("ChartCombo - Gráficos 3D não podem ser combinados")
	Endif
	AADD(::aCharts,{oChart,lEixoSecundario})
Return oChart

/*/{Protheus.doc} ChartCombo::AddSerie
Não utilizado na combinação - as séries pertencem aos gráficos membros
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@return object, self
@type method
/*/
Method AddSerie(cNome As Character, cRefVal As Character, cRefCat As Character, aVal As Array, aCat As Array, cCor As Character) as Object Class ChartCombo
	UserException("ChartCombo - Adicionar as séries nos gráficos membros e usar o método :AddChart()")
Return self

/*/{Protheus.doc} ChartCombo::Set3D
Combinação não suporta 3D
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@return object, self
@type method
/*/
Method Set3D(lAtivo As Logical, nRotX As Numeric, nRotY As Numeric, nPerspectiva As Numeric) as Object Class ChartCombo
	UserException(::cClassName+" - Combinação de gráficos não suporta 3D")
Return self

/*/{Protheus.doc} ChartCombo::ChecarSeries
Valida os gráficos membros antes da inserção
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@type method
/*/
Method ChecarSeries() Class ChartCombo
	Local nCont As Numeric
	If Len(::aCharts)<2
		UserException("ChartCombo - Adicionar ao menos 2 gráficos com o método :AddChart()")
	Endif
	For nCont:=1 to Len(::aCharts)
		If Empty(::aCharts[nCont][1]:aSeries)
			UserException("ChartCombo - Gráfico membro "+cValToChar(nCont)+" sem séries, usar :AddSerie() no membro")
		Endif
		If ::aCharts[nCont][1]:l3D
			UserException("ChartCombo - Gráficos 3D não podem ser combinados")
		Endif
	Next
Return

/*/{Protheus.doc} ChartCombo::XmlPlot
Gera os grupos dos gráficos membros compartilhando os eixos e, quando houver
membro no eixo secundário, o par de eixos secundário
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@return characters, XML do plotArea
@type method
/*/
Method XmlPlot() Class ChartCombo
	Local cXml := "" As Character
	Local nCont As Numeric
	Local nIdxAcum := 0 As Numeric
	Local lTemSec := .F. As Logical
	Local oChart As Object
	//Ids do par de eixos secundário deste gráfico
	::nIdEixoSec1	:= 100000004+(::nChart*10)
	::nIdEixoSec2	:= 100000005+(::nChart*10)
	For nCont:=1 to Len(::aCharts)
		oChart	:= ::aCharts[nCont][1]
		If ::aCharts[nCont][2]	//Membro no eixo secundário
			lTemSec	:= .T.
			oChart:nIdEixo1	:= ::nIdEixoSec1
			oChart:nIdEixo2	:= ::nIdEixoSec2
		Else	//Membro no eixo primário
			oChart:nIdEixo1	:= ::nIdEixo1
			oChart:nIdEixo2	:= ::nIdEixo2
		Endif
		//idx/order das séries devem ser únicos no plotArea inteiro
		cXml	+= oChart:XmlGrupo(nIdxAcum)
		nIdxAcum	+= Len(oChart:aSeries)
	Next
	cXml	+= ::XmlEixos("b","l")
	If lTemSec
		cXml	+= ::XmlEixosSec()
	Endif
Return cXml

/*/{Protheus.doc} ChartCombo::XmlEixosSec
Gera o par de eixos secundário: valores à direita e categorias oculto
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@return characters, XML dos eixos secundários
@type method
/*/
Method XmlEixosSec() Class ChartCombo
	Local cXml := "" As Character
	//Eixo de valores secundário (direita)
	cXml	+= '<c:valAx>'
	cXml	+= '<c:axId val="'+cValToChar(::nIdEixoSec2)+'"/>'
	cXml	+= '<c:scaling><c:orientation val="minMax"/></c:scaling>'
	cXml	+= '<c:delete val="0"/>'
	cXml	+= '<c:axPos val="r"/>'
	cXml	+= '<c:numFmt formatCode="General" sourceLinked="1"/>'
	cXml	+= '<c:tickLblPos val="nextTo"/>'
	cXml	+= '<c:crossAx val="'+cValToChar(::nIdEixoSec1)+'"/>'
	cXml	+= '<c:crosses val="max"/>'
	cXml	+= '<c:crossBetween val="between"/>'
	cXml	+= '</c:valAx>'
	//Eixo de categorias secundário (oculto)
	cXml	+= '<c:catAx>'
	cXml	+= '<c:axId val="'+cValToChar(::nIdEixoSec1)+'"/>'
	cXml	+= '<c:scaling><c:orientation val="minMax"/></c:scaling>'
	cXml	+= '<c:delete val="1"/>'
	cXml	+= '<c:axPos val="b"/>'
	cXml	+= '<c:tickLblPos val="nextTo"/>'
	cXml	+= '<c:crossAx val="'+cValToChar(::nIdEixoSec2)+'"/>'
	cXml	+= '<c:crosses val="autoZero"/>'
	cXml	+= '<c:auto val="1"/>'
	cXml	+= '<c:lblAlgn val="ctr"/>'
	cXml	+= '<c:lblOffset val="100"/>'
	cXml	+= '<c:noMultiLvlLbl val="0"/>'
	cXml	+= '</c:catAx>'
Return cXml

//----------------------------------------------------------------------
//FUNÇÕES AUXILIARES (estáticas do fonte)
//----------------------------------------------------------------------
/*/{Protheus.doc} XmlSerIni
Gera a abertura da série (c:ser com c:idx, c:order e c:tx)
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@param oSerie, object, Objeto Serie
@param nIdx, numeric, Índice da série (base zero)
@return characters, XML de abertura da série (sem fechar o c:ser)
@type function
/*/
Static Function XmlSerIni(oSerie As Object, nIdx As Numeric)
	Local cXml := "" As Character
	cXml	+= '<c:ser>'
	cXml	+= '<c:idx val="'+cValToChar(nIdx)+'"/>'
	cXml	+= '<c:order val="'+cValToChar(nIdx)+'"/>'
	If !Empty(oSerie:cNome)
		If "!" $ oSerie:cNome	//Nome por referência de célula (ex: "Dados!$B$1")
			cXml	+= '<c:tx>'+XmlStr(oSerie:cNome,{})+'</c:tx>'
		Else	//Nome literal
			cXml	+= '<c:tx><c:v>'+EscXml(oSerie:cNome)+'</c:v></c:tx>'
		Endif
	Endif
Return cXml

/*/{Protheus.doc} XmlCat
Gera as categorias da série (c:cat)
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@param oSerie, object, Objeto Serie
@return characters, XML das categorias (vazio se não informadas)
@type function
/*/
Static Function XmlCat(oSerie As Object)
	Local cXml := "" As Character
	If !Empty(oSerie:cRefCat) .or. !Empty(oSerie:aCat)
		cXml	+= '<c:cat>'+XmlStr(oSerie:cRefCat,oSerie:aCat)+'</c:cat>'
	Endif
Return cXml

/*/{Protheus.doc} XmlVal
Gera os valores da série (c:val)
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@param oSerie, object, Objeto Serie
@return characters, XML dos valores
@type function
/*/
Static Function XmlVal(oSerie As Object)
	Local cXml := "" As Character
	If Empty(oSerie:cRefVal) .and. Empty(oSerie:aVal)
		UserException("Chart - Série sem valores, informar cRefVal ou aVal no :AddSerie()")
	Endif
	cXml	+= '<c:val>'+XmlNum(oSerie:cRefVal,oSerie:aVal)+'</c:val>'
Return cXml

/*/{Protheus.doc} XmlStr
Gera referência de texto (c:strRef com c:strCache) ou literal (c:strLit)
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@param cRef, characters, Referência de células (opcional)
@param aValores, array, Valores literais (opcional, gera cache)
@return characters, XML da referência
@type function
/*/
Static Function XmlStr(cRef As Character, aValores As Array)
	Local cXml := "" As Character
	Local nCont As Numeric
	Default cRef		:= ""
	Default aValores	:= {}
	If !Empty(cRef)
		cXml	+= '<c:strRef>'
		cXml	+= '<c:f>'+EscXml(cRef)+'</c:f>'
		If !Empty(aValores)	//Cache opcional dos valores
			cXml	+= '<c:strCache>'
			cXml	+= '<c:ptCount val="'+cValToChar(Len(aValores))+'"/>'
			For nCont:=1 to Len(aValores)
				cXml	+= '<c:pt idx="'+cValToChar(nCont-1)+'"><c:v>'+EscXml(aValores[nCont])+'</c:v></c:pt>'
			Next
			cXml	+= '</c:strCache>'
		Endif
		cXml	+= '</c:strRef>'
	Else	//Somente valores literais
		cXml	+= '<c:strLit>'
		cXml	+= '<c:ptCount val="'+cValToChar(Len(aValores))+'"/>'
		For nCont:=1 to Len(aValores)
			cXml	+= '<c:pt idx="'+cValToChar(nCont-1)+'"><c:v>'+EscXml(aValores[nCont])+'</c:v></c:pt>'
		Next
		cXml	+= '</c:strLit>'
	Endif
Return cXml

/*/{Protheus.doc} XmlNum
Gera referência numérica (c:numRef com c:numCache) ou literal (c:numLit)
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@param cRef, characters, Referência de células (opcional)
@param aValores, array, Valores literais (opcional, gera cache)
@return characters, XML da referência
@type function
/*/
Static Function XmlNum(cRef As Character, aValores As Array)
	Local cXml := "" As Character
	Local nCont As Numeric
	Default cRef		:= ""
	Default aValores	:= {}
	If !Empty(cRef)
		cXml	+= '<c:numRef>'
		cXml	+= '<c:f>'+EscXml(cRef)+'</c:f>'
		If !Empty(aValores)	//Cache opcional dos valores
			cXml	+= '<c:numCache>'
			cXml	+= '<c:formatCode>General</c:formatCode>'
			cXml	+= '<c:ptCount val="'+cValToChar(Len(aValores))+'"/>'
			For nCont:=1 to Len(aValores)
				cXml	+= '<c:pt idx="'+cValToChar(nCont-1)+'"><c:v>'+EscXml(aValores[nCont])+'</c:v></c:pt>'
			Next
			cXml	+= '</c:numCache>'
		Endif
		cXml	+= '</c:numRef>'
	Else	//Somente valores literais
		cXml	+= '<c:numLit>'
		cXml	+= '<c:ptCount val="'+cValToChar(Len(aValores))+'"/>'
		For nCont:=1 to Len(aValores)
			cXml	+= '<c:pt idx="'+cValToChar(nCont-1)+'"><c:v>'+EscXml(aValores[nCont])+'</c:v></c:pt>'
		Next
		cXml	+= '</c:numLit>'
	Endif
Return cXml

/*/{Protheus.doc} XmlCor
Gera preenchimento sólido com a cor informada (a:solidFill)
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@param cCor, characters, Cor RGB (6 dígitos) ou ARGB (8 dígitos, o alfa é descartado)
@return characters, XML do preenchimento
@type function
/*/
Static Function XmlCor(cCor As Character)
	cCor	:= UPPER(AllTrim(cCor))
	If Len(cCor)==8	//ARGB usado pela classe Xlsx, remove o canal alfa
		cCor	:= SubStr(cCor,3)
	Endif
Return '<a:solidFill><a:srgbClr val="'+cCor+'"/></a:solidFill>'

/*/{Protheus.doc} EscXml
Escapa os caracteres reservados do XML e converte o texto para UTF-8
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@param xTexto, variadic, Texto ou valor a ser escapado
@return characters, Texto seguro para uso no XML
@type function
/*/
Static Function EscXml(xTexto As Variant)
	Local cTexto As Character
	Local cUtf8 As Character
	If ValType(xTexto)=="C"
		cTexto	:= xTexto
	Else
		cTexto	:= cValToChar(xTexto)
	Endif
	cTexto	:= StrTran(cTexto,"&","&amp;")
	cTexto	:= StrTran(cTexto,"<","&lt;")
	cTexto	:= StrTran(cTexto,">","&gt;")
	cTexto	:= StrTran(cTexto,'"',"&quot;")
	cTexto	:= StrTran(cTexto,"'","&apos;")
	cUtf8	:= EncodeUTF8(cTexto)	//O XML das partes é gravado em UTF-8
	If ValType(cUtf8)=="C"
		cTexto	:= cUtf8
	Endif
Return cTexto

/*/{Protheus.doc} AjustNs
Ajusta o prefixo de namespace dos nodes criados pelo TXmlManager
(mesma técnica da função ajustNS do fonte custom.excel.tlpp) e
registra novamente os namespaces para as consultas XPath
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@param oXml, object, TXmlManager do drawing
@param cDe, characters, Texto a ser substituído (ex: "<xdr:a:")
@param cPara, characters, Texto substituto (ex: "<a:")
@type function
/*/
Static Function AjustNs(oXml As Object, cDe As Character, cPara As Character)
	Local aNs As Array
	Local nCont As Numeric
	oXml:Parse(Replace(oXml:Save2String(),cDe,cPara))
	aNs	:= oXml:XPathGetRootNsList()
	For nCont:=1 to Len(aNs)
		oXml:XPathRegisterNs( aNs[nCont][1], aNs[nCont][2] )
	Next
	//Prefixos usados pelo gráfico que não estão declarados na raiz do drawing
	oXml:XPathRegisterNs( "c", NS_CHART )
	oXml:XPathRegisterNs( "r", NS_REL )
Return
