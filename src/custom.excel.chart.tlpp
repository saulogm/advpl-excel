//GR┴FICO DE DISPERS├O
//----------------------------------------------------------------------
/*/{Protheus.doc} ChartScatter
Grßfico de dispersŃo XY (c:scatterChart - ECMA-376 ¦21.2.2.161)
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@type class
@see custom.excel.chart.Chart
@obs Usa dois eixos de valores. Informar as sķries com :AddSerie() usando
cRefCat/aCat como X e cRefVal/aVal como Y, ou usar o mķtodo :SetXY() da sķrie
/*/
Class ChartScatter from Chart
	Public Data cEstilo			As Character	//Estilo: marker, lineMarker, smoothMarker, line, smooth

	Public Method New()			As Object
	Public Method SetEstilo()	As Object
	Public Method Set3D()		As Object
	Public Method XmlPlot()
	Public Method XmlSer()
	Public Method XmlEixosVal()
EndClass

/*/{Protheus.doc} ChartScatter::New
Construtor do grßfico de dispersŃo
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@param oExcel, object, InstŌncia da classe custom.excel.Xlsx
@return object, self
@type method
/*/
Method New(oExcel As Object) as Object Class ChartScatter
	_Super:New(oExcel)
	::cClassName	:= "CUSTOM.EXCEL.CHART.CHARTSCATTER"
	::cEstilo		:= "marker"
Return self

/*/{Protheus.doc} ChartScatter::SetEstilo
Define o estilo da dispersŃo
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@param cEstilo, characters, marker=pontos, lineMarker=linhas com pontos, smoothMarker=suavizada com pontos, line=linhas, smooth=suavizada
@return object, self
@type method
/*/
Method SetEstilo(cEstilo As Character) as Object Class ChartScatter
	PARAMTYPE 0	VAR cEstilo		AS CHARACTER
	If !(cEstilo=="marker" .or. cEstilo=="lineMarker" .or. cEstilo=="smoothMarker" .or. cEstilo=="line" .or. cEstilo=="smooth")
		UserException("ChartScatter - Estilo invßlido ("+cEstilo+"). Usar: marker,lineMarker,smoothMarker,line,smooth")
	Endif
	::cEstilo	:= cEstilo
Return self

/*/{Protheus.doc} ChartScatter::Set3D
DispersŃo e bolhas nŃo possuem versŃo 3D no ECMA-376
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@return object, self
@type method
/*/
Method Set3D(lAtivo As Logical, nRotX As Numeric, nRotY As Numeric, nPerspectiva As Numeric) as Object Class ChartScatter
	UserException(::cClassName+" - Este tipo de grßfico nŃo possui versŃo 3D no ECMA-376")
Return self

/*/{Protheus.doc} ChartScatter::XmlPlot
Gera o c:scatterChart e os dois eixos de valores
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@return characters, XML do plotArea
@type method
/*/
Method XmlPlot() Class ChartScatter
	Local cXml := "" As Character
	Local nCont As Numeric
	cXml	+= '<c:scatterChart>'
	cXml	+= '<c:scatterStyle val="'+::cEstilo+'"/>'
	cXml	+= '<c:varyColors val="0"/>'
	For nCont:=1 to Len(::aSeries)
		cXml	+= ::XmlSer(::aSeries[nCont],nCont-1)
	Next
	cXml	+= '<c:axId val="'+cValToChar(::nIdEixo1)+'"/>'
	cXml	+= '<c:axId val="'+cValToChar(::nIdEixo2)+'"/>'
	cXml	+= '</c:scatterChart>'
	cXml	+= ::XmlEixosVal()
Return cXml

/*/{Protheus.doc} ChartScatter::XmlSer
Gera uma sķrie do grßfico de dispersŃo (c:ser com c:xVal/c:yVal)
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@param oSerie, object, Objeto Serie
@param nIdx, numeric, ═ndice da sķrie (base zero)
@return characters, XML da sķrie
@type method
/*/
Method XmlSer(oSerie As Object, nIdx As Numeric) Class ChartScatter
	Local cXml := "" As Character
	Local cRefX As Character
	Local cRefY As Character
	Local aX As Array
	Local aY As Array
	Local lLinha As Logical
	Local lSuavizar As Logical
	//X/Y podem ser informados via SetXY ou reaproveitando cRefCat/cRefVal do AddSerie
	cRefX		:= If(!Empty(oSerie:cRefX),oSerie:cRefX,oSerie:cRefCat)
	cRefY		:= If(!Empty(oSerie:cRefY),oSerie:cRefY,oSerie:cRefVal)
	aX			:= If(!Empty(oSerie:aX),oSerie:aX,oSerie:aCat)
	aY			:= If(!Empty(oSerie:aY),oSerie:aY,oSerie:aVal)
	lLinha		:= ::cEstilo=="lineMarker" .or. ::cEstilo=="smoothMarker" .or. ::cEstilo=="line" .or. ::cEstilo=="smooth"
	lSuavizar	:= ::cEstilo=="smoothMarker" .or. ::cEstilo=="smooth"
	If ValType(oSerie:xSuavizar)=="L"
		lSuavizar	:= oSerie:xSuavizar
	Endif
	cXml	+= XmlSerIni(oSerie,nIdx)
	//Linha da sķrie (oculta quando estilo somente pontos)
	If !lLinha
		cXml	+= '<c:spPr><a:ln w="19050"><a:noFill/></a:ln></c:spPr>'
	ElseIf !Empty(oSerie:cCor)
		cXml	+= '<c:spPr><a:ln w="19050">'+XmlCor(oSerie:cCor)+'</a:ln></c:spPr>'
	Endif
	//Marcador dos pontos
	If ::cEstilo=="line" .or. ::cEstilo=="smooth"
		cXml	+= '<c:marker><c:symbol val="none"/></c:marker>'
	Else
		cXml	+= '<c:marker><c:symbol val="circle"/><c:size val="5"/>'
		If !Empty(oSerie:cCor)
			cXml	+= '<c:spPr>'+XmlCor(oSerie:cCor)+'</c:spPr>'
		Endif
		cXml	+= '</c:marker>'
	Endif
	//Valores X e Y (numķricos)
	cXml	+= '<c:xVal>'+XmlNum(cRefX,aX)+'</c:xVal>'
	cXml	+= '<c:yVal>'+XmlNum(cRefY,aY)+'</c:yVal>'
	cXml	+= '<c:smooth val="'+If(lSuavizar,"1","0")+'"/>'
	cXml	+= '</c:ser>'
Return cXml

/*/{Protheus.doc} ChartScatter::XmlEixosVal
Gera os dois eixos de valores da dispersŃo/bolhas (X embaixo, Y Ó esquerda)
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@return characters, XML dos eixos
@type method
/*/
Method XmlEixosVal() Class ChartScatter
	Local cXml := "" As Character
	//Eixo X (valores)
	cXml	+= '<c:valAx>'
	cXml	+= '<c:axId val="'+cValToChar(::nIdEixo1)+'"/>'
	cXml	+= '<c:scaling><c:orientation val="minMax"/></c:scaling>'
	cXml	+= '<c:delete val="0"/>'
	cXml	+= '<c:axPos val="b"/>'
	cXml	+= '<c:numFmt formatCode="General" sourceLinked="1"/>'
	cXml	+= '<c:tickLblPos val="nextTo"/>'
	cXml	+= '<c:crossAx val="'+cValToChar(::nIdEixo2)+'"/>'
	cXml	+= '<c:crosses val="autoZero"/>'
	cXml	+= '<c:crossBetween val="midCat"/>'
	cXml	+= '</c:valAx>'
	//Eixo Y (valores)
	cXml	+= '<c:valAx>'
	cXml	+= '<c:axId val="'+cValToChar(::nIdEixo2)+'"/>'
	cXml	+= '<c:scaling><c:orientation val="minMax"/></c:scaling>'
	cXml	+= '<c:delete val="0"/>'
	cXml	+= '<c:axPos val="l"/>'
	If ::lGrade
		cXml	+= '<c:majorGridlines/>'
	Endif
	cXml	+= '<c:numFmt formatCode="General" sourceLinked="1"/>'
	cXml	+= '<c:tickLblPos val="nextTo"/>'
	cXml	+= '<c:crossAx val="'+cValToChar(::nIdEixo1)+'"/>'
	cXml	+= '<c:crosses val="autoZero"/>'
	cXml	+= '<c:crossBetween val="midCat"/>'
	cXml	+= '</c:valAx>'
Return cXml

