	Public Method XmlPlot()
	Public Method XmlSer()
EndClass

/*/{Protheus.doc} ChartRadar::New
Construtor do gráfico de radar
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@param oExcel, object, Instância da classe custom.excel.Xlsx
@return object, self
@type method
/*/
Method New(oExcel As Object) as Object Class ChartRadar
	_Super:New(oExcel)
	::cClassName	:= "CUSTOM.EXCEL.CHART.CHARTRADAR"
	::cEstilo		:= "standard"
Return self

/*/{Protheus.doc} ChartRadar::SetEstilo
Define o estilo do radar
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@param cEstilo, characters, standard=linhas, marker=linhas com pontos, filled=preenchido
@return object, self
@type method
/*/
Method SetEstilo(cEstilo As Character) as Object Class ChartRadar
	PARAMTYPE 0	VAR cEstilo		AS CHARACTER
	If !(cEstilo=="standard" .or. cEstilo=="marker" .or. cEstilo=="filled")
		UserException("ChartRadar - Estilo inválido ("+cEstilo+"). Usar: standard,marker,filled")
	Endif
	::cEstilo	:= cEstilo
Return self

/*/{Protheus.doc} ChartRadar::Set3D
Radar não possui versão 3D no ECMA-376
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@return object, self
@type method
/*/
Method Set3D(lAtivo As Logical, nRotX As Numeric, nRotY As Numeric, nPerspectiva As Numeric) as Object Class ChartRadar
	UserException(::cClassName+" - Este tipo de gráfico não possui versão 3D no ECMA-376")
Return self

/*/{Protheus.doc} ChartRadar::XmlPlot
Gera o c:radarChart e os eixos
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@return characters, XML do plotArea
@type method
/*/
Method XmlPlot() Class ChartRadar
	Local cXml := "" As Character
	Local nCont As Numeric
	cXml	+= '<c:radarChart>'
	cXml	+= '<c:radarStyle val="'+::cEstilo+'"/>'
	cXml	+= '<c:varyColors val="0"/>'
	For nCont:=1 to Len(::aSeries)
		cXml	+= ::XmlSer(::aSeries[nCont],nCont-1)
	Next
	cXml	+= '<c:axId val="'+cValToChar(::nIdEixo1)+'"/>'
	cXml	+= '<c:axId val="'+cValToChar(::nIdEixo2)+'"/>'
	cXml	+= '</c:radarChart>'
	cXml	+= ::XmlEixos("b","l")
Return cXml

/*/{Protheus.doc} ChartRadar::XmlSer
Gera uma série do gráfico de radar (c:ser)
@author Saulo Gomes Martins
@since 04/07/2026
@version 1.0
@param oSerie, object, Objeto Serie
@param nIdx, numeric, Índice da série (base zero)
@return characters, XML da série
@type method
/*/
Method XmlSer(oSerie As Object, nIdx As Numeric) Class ChartRadar
	Local cXml := "" As Character
	cXml	+= XmlSerIni(oSerie,nIdx)
	If !Empty(oSerie:cCor)
		If ::cEstilo=="filled"
			cXml	+= '<c:spPr>'+XmlCor(oSerie:cCor)+'</c:spPr>'	//Radar preenchido: cor no preenchimento
		Else
			cXml	+= '<c:spPr><a:ln w="28575">'+XmlCor(oSerie:cCor)+'</a:ln></c:spPr>'	//Cor na linha
		Endif
	Endif
	If ::cEstilo=="marker"
		cXml	+= '<c:marker><c:symbol val="circle"/><c:size val="5"/>'
		If !Empty(oSerie:cCor)
			cXml	+= '<c:spPr>'+XmlCor(oSerie:cCor)+'</c:spPr>'
		Endif
		cXml	+= '</c:marker>'
	Else
		cXml	+= '<c:marker><c:symbol val="none"/></c:marker>'
	Endif
	cXml	+= XmlCat(oSerie)
	cXml	+= XmlVal(oSerie)
	cXml	+= '</c:ser>'
Return cXml

