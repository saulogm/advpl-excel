Class Varariavel
	Public Data cTipo				As Character //T=TEXTO;N=NUMERO;L=LOGICO;R=REFERENCIA;F=FUNÇĂO;E=EXPRESSĂO
	Public Data xValor				As Variant //VALOR
	Public Data cFuncao			As Character //Nome da funçăo
	Public Data cPrefixOper		As Character //Operador inicio
	Public Data cPosfixOper		As Character //Operador final
	Public Data cFormula    As Character
	Public Method New()    As Object
	Public Method GetValue()
	Public Method SetValue()
	Public Method ADDValue()
	Public Method GetLen()
	Public Method SetType()
	Public Method SetFomula()
	Public Method GetPre()
	Public Method SetPre()
	Public Method SetPos()
	Public Method SetFuncao()
EndClass

Method New(cTipo As Character) as Object Class Varariavel
	::xValor		:= {}
	::cTipo			:= cTipo
Return Self

Method GetValue() Class Varariavel
Return ::xValor

Method GetLen() Class Varariavel
Return Len(::xValor)

Method SetValue(xValor As Variant) Class Varariavel
	::xValor	:= xValor
Return self

Method ADDValue(xValorPar As Variant) Class Varariavel
	// Local oValor	:= Var():New()
	AADD(::xValor,xValorPar)
	// oValor:SetValue(xValor)
Return xValorPar

Method SetType(cTipo As Character) Class Varariavel
	::cTipo	:= cTipo
Return self

Method SetFomula(cFormula As Character) Class Varariavel
	::cFormula	:= cFormula
Return self

Method GetPre(cPrefixOper As Character) Class Varariavel
Return ::cPrefixOper

Method SetPre(cPrefixOper As Character) Class Varariavel
	::cPrefixOper	:= cPrefixOper
	cPrefixOper		:= ""
Return self

Method SetPos(cPosfixOper As Character) Class Varariavel
	::cPosfixOper	:= cPosfixOper
	cPosfixOper		:= ""
Return self

Method SetFuncao(cFuncao As Character) Class Varariavel
	::cFuncao	:= cFuncao
Return self

Static aAriOpe	:= {"-","%","^","*","/","+"}
Static cTexOpe := "&" As Character
Static aLogOpe := {"=","<",">"} As Array//{"=","<>","<","<=",">",">="}

Static aModicadores := {"(",")","=","+","%","^","*","/","+","&","<",">",","}

User Function ytstfor2()
	Local cFormula := '"Valor:"&A1+SUM(C3:C4)+123.132*' As Character
	Local oRet As Object
	oParseFor	:= Formula():New()
	oRet	:= oParseFor:Parse(cFormula)
	VarInfo("oRet",oRet,,.F.)
Return

Class Formula
	Public Data aDados    As Array
	Public Method New()    As Object
	Public Method Parse()
EndClass

Method New() Class Formula
Return self

Method Parse(cFormula As Character, nQtdLido As Numeric) Class Formula
	Local cTexto := "" As Character
	Local cTexto2 := "" As Character
	Local nTam := Len(cFormula) As Numeric
	Local cTipo := "" As Character
	Local cNumero := "" As Character
	Local cValor As Character
	Local lRef As Logical
	Local oRet := yExcelVar():New() As Object
	Local nQtdSoma := 0 As Numeric
	Local cPre := "" As Character
	Local cPos As Character
	Local nCont As Numeric
	Local oTmp As Object

	nQtdLido		:= 0
	oRet:SetValue(Array(0))
	For nCont:=1 to Len(cFormula)
		nQtdSoma	:= 0
		cNumero		:= ""
		cValor		:= ""
		cTexto		:= SubStr(cFormula,nCont,1)
		cTexto2		:= SubStr(cFormula,nCont+1,1)	//Proximo letra
		cTipo		:= tpExpressao(cTexto)
		If cTexto=='"'	//Texto
			cValor		:= ""
			nCont++
			While nCont<=nTam
				cTexto		:= SubStr(cFormula,nCont,1)
				If cTexto=='"'
					Exit
				Endif
				cValor		+= cTexto
				nCont++
			EndDo
			oTmp:=Varariavel():New()
			oTmp:SetValue(cValor):SetType("T"):SetPre(@cPre):SetPos(@cPos)
			oRet:ADDValue(oTmp)
		ElseIf aScan(aAriOpe,cTexto)>0	//Operadores simples
			cPre	+= cTexto
		ElseIf aScan(aLogOpe,cTexto)>0	//Operadores logicos
				cPre	+= cTexto
		ElseIf cTexto=="&"				//Operadores texto
			cPre	+= cTexto
		ElseIf cTexto=="("
			oTmp	:= ::Parse(SubStr(cFormula,nCont+1),@nQtdSoma)
			oTmp:SetFuncao("("):SetType("E"):SetPre(@cPre):SetPos(@cPos)
			oRet:ADDValue(oTmp)
			nCont	+= nQtdSoma+2			
		ElseIf cTexto==")"	//Sair da funçăo
			Exit
		ElseIf cTexto==","
			Loop
		ElseIf cTipo=="N"
			cNumero	:= cTexto
			While (cTexto2=="." .OR. tpExpressao(cTexto2)=="N") .AND. nCont<=nTam
				cNumero	+= cTexto2
				nCont++
				cTexto2	:= SubStr(cFormula,nCont+1,1)
			EndDo
			oTmp:=Varariavel():New()
			oTmp:SetValue(Val(cNumero)):SetType("N"):SetPre(@cPre):SetPos(@cPos)
			oRet:ADDValue(oTmp)
		ElseIf cTipo=="C"
			lRef		:= .F.
			cValor		:= ""
			While aScan(aModicadores,cTexto)==0 .AND. nCont<=nTam
				If tpExpressao(cTexto)=="N" .OR. cTexto==":"
					lRef		:= .T.
				Endif
				cValor		+= cTexto
				nCont++
				cTexto		:= SubStr(cFormula,nCont,1)
			EndDo
			If lRef
				oTmp:=Varariavel():New()
				oTmp:SetValue(cValor):SetType("R"):SetPre(@cPre):SetPos(@cPos)
				oRet:ADDValue(oTmp)
			ElseIf cTexto=="("		//Formula
				// oRet:SetFuncao(cValor)
				oTmp	:= ::Parse(SubStr(cFormula,nCont+1),@nQtdSoma)
				oTmp:SetFuncao(cValor):SetType("F"):SetPre(@cPre):SetPos(@cPos)
				oRet:ADDValue(oTmp)
				nCont	+= nQtdSoma+2
			ElseIf cValor=="TRUE".or.cValor=="FALSE"
				oTmp:=Varariavel():New()
				oTmp:SetValue(cValor=="TRUE"):SetType("L"):SetPre(@cPre):SetPos(@cPos)
				oRet:ADDValue(oTmp)
			Else
				oTmp:=Varariavel():New()
				oTmp:SetValue(cValor):SetType("R"):SetPre(@cPre):SetPos(@cPos)
				oRet:ADDValue(oTmp)
			Endif
			nCont--
		Endif
	Next
	// If !Empty(cPos) .AND. oRet:GetLen()>0
	// 	oRet:GetValue()[oRet:GetLen()]:SetPos(@cPos)
	// Endif
	nQtdLido	:= nCont-1
	oRet:SetFomula(SubStr(cFormula,1,nQtdLido))
Return oRet

Static Function tpExpressao(cExpression As Character)
	Local cTipo :="" As Character
	Local nAscii := asc(cExpression) As Numeric
	If nAscii>=48 .and. nAscii<=57	//Numeros
		cTipo	:= "N"
	ElseIf nAscii>=65 .and. nAscii<=90	//Letra Maisculas
		cTipo	:= "C"
	ElseIf nAscii>=97 .and. nAscii<=122	//Letra Minusculas
		cTipo	:= "C"
	Endif
Return cTipo

Static Function lTem7Zip(oSelf As Object)
	If ValType(cRootPath)=="U"
		cRootPath	:= GetSrvProfString( "RootPath", "" )
		If !File(cRootPath,1)	//Validar o RootPath existe no servidor
			UserException("Xlsx, erro RootPath:"+cRootPath)
		EndIf
	Endif
	MemoWrite("\tmpxls\"+oSelf:cTmpFile+"\fileexist.bat",'IF EXIST "'+cAr7Zip+'" ( ECHO 1 >> "'+cRootPath+'\tmpxls\'+oSelf:cTmpFile+'\1.txt" ) ELSE ( ECHO 2 >> "'+cRootPath+'\tmpxls\'+oSelf:cTmpFile+'\2.txt" )')
	WaitRunSrv(cRootPath+'\tmpxls\'+oSelf:cTmpFile+'\fileexist.bat',.T.,"C:\")
	If File("\tmpxls\"+oSelf:cTmpFile+"\1.txt")//!FindFunction("FZIP")
		c7Zip	:= "S"
		fErase("\tmpxls\"+oSelf:cTmpFile+"\1.txt")
	Else
		c7Zip	:= "N"
		fErase("\tmpxls\"+oSelf:cTmpFile+"\2.txt")
	Endif
	fErase("\tmpxls\"+oSelf:cTmpFile+"\fileexist.bat")
Return
