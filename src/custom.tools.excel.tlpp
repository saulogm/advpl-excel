/*/
Method SetStyborder(nStyle As Numeric, borderId As Object) Class Xlsx
	Local cLocal := "/xmlns:styleSheet/xmlns:cellXfs" As Character
	Local cXPath := cLocal+"/xmlns:xf["+cValToChar(nStyle+1)+"]" As Character
	Local aChave As Array
	Local cChave As Character
	PARAMTYPE 0	VAR nStyle			AS NUMERIC
	PARAMTYPE 1	VAR borderId		AS NUMERIC		OPTIONAL
	
	If nStyle+1>::nQtdStyle
