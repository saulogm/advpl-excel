	Public Data aworkdrawing	As Array //arquivo drawing do worksheets
	Public Data odrawing		As Object //tag drawing dentro do sheet
	Public Data aImagens		As Array //Imagens adicionada
	Public Data aImgdraw		As Array //Imagens usada no sheets(pode usar mais de uma vez a mesma imagem)
	Public Data nIDMedia		As Numeric //Sequencial do id da imagem

	Public Data aRels			As Array //Arquivos rels
