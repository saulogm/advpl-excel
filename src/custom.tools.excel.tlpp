	Public METHOD AddSubTotal()	//Cria nova definiçăo de subtotal para alias2tab
	
	Public METHOD InsertRowEmpty()	//Cria linhas vazia
	Public METHOD InsertCellEmpty()//Cria células vazias
	Public METHOD NivelLinha()
	Public METHOD SetsumBelow()	//Configurar linha resumo de agrupamento de linhas abaixo
	Public METHOD SetsumRight()	//Configurar coluna resumo a direita
