/*/{Protheus.doc} DateTime:StrNumber
Converte data e hora em string com numero representando data e hora do excel
@author Saulo Gomes Martins
@since 10/12/2019
@version 1.0

@type method
/*/
Method StrNumber() Class DateTime
	Local aHora := SeparaHora(::cTime) As Array
	Local nSeg := 0 As Numeric
	Local cNum As Character
	Local f1SegDec := DEC_CREATE( "0.00001157407407407407" , 20, 19 ) As Variant
	Local fSeg As Variant
	Local fMult As Variant
	Local fMult2 As Variant
	Local fSub As Variant
	Local f10 As Variant
	Local fMultFim As Variant
	nSeg		+= aHora[1]*3600
	nSeg		+= aHora[2]*60
	nSeg		+= aHora[3]
	nSeg		+= aHora[4]/1000
	fSeg		:= DEC_CREATE(cValToChar(nSeg),20, 19)
	fMult		:= DEC_MUL(fSeg,f1SegDec)
	fMult2		:= DEC_MUL(fSeg,f1SegDec)
	fMult2		:= DEC_RESCALE(fMult2, 8, 2)
	fSub		:= DEC_SUB(fMult,fMult2)
	f10			:= DEC_CREATE("10000000000000000",20, 19)
	fMultFim	:= DEC_MUL(f10,fSub)

	::nDecimal	:= Int(Val(cValToChar(DEC_RESCALE( fMultFim , 8, 2))))
	cNum		:= Replace(cValToChar(DEC_RESCALE(fMult, 8, 2)),"0.","")
	// nHora		+= (aHora[1]*100000000)				//Hora
	// nHora		+= (aHora[2]*100000000)/60			//Minuto
	// nHora		+= (aHora[3]*100000000)/60/60		//Segundo
	// nHora		+= (aHora[4]*100000000)/60/60/1000	//Milesimo
	// cNum		:= Replace(cValToChar(nHora/24),"0.","")
	// If (At(".",cNum)-1)>0
	// 	cNum:= SubStr(cNum,1,At(".",cNum)-1)
	// Else
	// 	cNum:= SubStr(cNum,1,Len(cNum))
	// Endif
	::cNumero	:= cValToChar(::dData-STOD("19000101")+2)+"."+cNum
	::nNumero	:= ::dData-STOD("19000101")+2+(&("0."+SubStr(cNum,1,8)))
	// If Len(cNum)>8
	// 	::nDecimal	:= &("0."+SubStr(cNum,9)+"*(10^8)")
	// Endif
Return ::cNumero

METHOD ClassName() Class DateTime
Return "DateTime"
//// ============================================================
//// Sobrecarga de Operadores - Class DateTime
//// Regras de tipo do operando direito (oRight):
////   Numeric  -> considera dias
////   Date     -> considera serial da data (dias desde 30/12/1899)
////   Character -> considera hora no formato HH:mm[:ss]
//// ============================================================

//// Soma: DateTime + dias(N) | data(D) | hora HH:mm[:ss](C)
//Operator Add(oRight As Variant) As Object Class DateTime
//    Local nSelf    As Numeric
//    Local nRight   As Numeric
//    Local nResult  As Numeric
//    Local aSepHora As Array

//    nSelf := Val(Self:cNumero)
//    Do Case
//    Case ValType(oRight) == "N"
//        nRight := oRight
//    Case ValType(oRight) == "D"
//        nRight := oRight - CToD("30/12/1899")
