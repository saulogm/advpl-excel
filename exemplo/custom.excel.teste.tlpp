/*/{Protheus.doc} TesteyExcel
Teste de geraþÒo de planilha cÚlula a cÚlula, sem uso de bulk
@type function
@version 1.0
@author Saulo Gomes Martins
@since 04/07/2026
/*/
Static Function TesteyExcel()
	Local nCont As Numeric
	Local nCont2 As Numeric
	Local cSubTotais As Character
	Local oExcel := YExcel():New(cNomeFile = "Pasta1", cTipo = "A") As Object
	Local nPosBorda2 := oExcel:Borda("ALL") As Numeric
	Local nPosBordas := oExcel:AddStyles(nborderId = nPosBorda2) As Numeric
	oExcel:ADDPlan(/*cNome*/)		//Adiciona uma planilha em branco
	// oExcel:SetDefRow(.F.,{1,4})	//Definir a coluna inicial e final da linha, importante para performace da classe
	oExcel:Cell(nLinha = 1, nColuna = 1, xValor = "Linha", xStyle = nPosBordas)
	oExcel:Cell(nLinha = 1, nColuna = 2, xValor = "Filial", xStyle = nPosBordas)
	oExcel:Cell(nLinha = 1, nColuna = 3, xValor = "Venda", xStyle = nPosBordas)
	oExcel:Cell(nLinha = 1, nColuna = 4, xValor = "Data Venda", xStyle = nPosBordas)
	nCont2	:= 1
	cSubTotais	:= ""
	For nCont:=2 to 10000
		oExcel:Pos(nCont,1):SetValue(nCont)
		oExcel:Pos(nCont,2):SetValue("Filial"+cValtoChar(nCont))
		oExcel:Pos(nCont,3):SetValue(Randomize(1,100))
		oExcel:Pos(nCont,4):SetValue(date()+nCont)
	Next
	oExcel:Gravar(cLocal = "c:\temp", lAbrir = .F., lDelSrv = .T.)
Return

/*/{Protheus.doc} tstBulk
Teste de geraþÒo de planilha em massa (bulk) gravando em arquivo temporario de banco
@type function
@version 1.0
@author Saulo Gomes Martins
@since 04/07/2026
/*/
Static Function tstBulk()
	Local nCont As Numeric
	Local nCont2 As Numeric
	Local cSubTotais As Character
	Local oExcel := YExcel():New(cNomeFile = "Pasta1", cTipo = "B") As Object
	Local nPosBorda2 := oExcel:Borda("ALL") As Numeric
	//Local nPosCorI		:= oExcel:CorPreenc("FFB8CCE4")	//Cor de Fundo Azul impa
	Local nPosBordas := oExcel:NewStyle():Setborder(nPosBorda2) As Object
	//Local oRegEst1 		:= oExcel:NewStyRules()
	//oRegEst1:AddStyle({|nLin,nCol,oObjExcel| nLin % 2 ==1 }, oExcel:NewStyle(nPosBordas):Setfill(nPosCorI) )	//Linhas Ýmpar aplica estilo herdados com borda e fundo azul
	//Local oPosFill		:= oExcel:NewStyle():Setfill(oExcel:CorPreenc("FF0000"))
	Local aCampos := {} As Array
	Local aRegraStyle As Variant
	Local nElapsed As Numeric
	Local nStart As Numeric
	oExcel:ADDPlan(/*cNome*/)		//Adiciona uma planilha em branco
	// oExcel:SetDefRow(.F.,{1,4})	//Definir a coluna inicial e final da linha, importante para performace da classe
	oExcel:Cell(nLinha = 1, nColuna = 1, xValor = "Linha", xStyle = nPosBordas)
	oExcel:Cell(nLinha = 1, nColuna = 2, xValor = "Filial", xStyle = nPosBordas)
	oExcel:Cell(nLinha = 1, nColuna = 3, xValor = "Venda", xStyle = nPosBordas)
	oExcel:Cell(nLinha = 1, nColuna = 4, xValor = "Data Venda", xStyle = nPosBordas)
	//BulkNewField(nColuna,cTipo,nTamanho,cCombo,oStyle,lFormula,lDatetime,cCampo,cDados)
	AADD(aCampos,oExcel:BulkNewField(nColuna = 1, cTipo = "N"))
	AADD(aCampos,oExcel:BulkNewField(nColuna = 2, cTipo = "C", nTamanho = 12))
	AADD(aCampos,oExcel:BulkNewField(nColuna = 3, cTipo = "N"))
	//AADD(aCampos,oExcel:BulkNewField(3,"C","1=Sim;2=NÒo"))
	AADD(aCampos,oExcel:BulkNewField(nColuna = 4, cTipo = "D"))

	//aRegraStyle	:= oExcel:NewRuleLine({|| If(nCont%10==0,"vermelho","") },{"vermelho",oPosFill,.F.}):GetArray()
	//oExcel:SetsumBelow(.T.)				//Defini que o agrupamento de linhas vai ser em baixo
	//oExcel:SetsumRight(.F.)				//Defini que o agrupamento vai ser na esquerda
	//oExcel:SetColLevel(4,5,1,.T.)		//Agrupa coluna 4 e 5 fechado

	oExcel:DefBulkLine(aCampos = aCampos, xRegraStyle = aRegraStyle, lMontarLin = .F.)
	cSubTotais	:= ""
	oExcel:nLinha	:= 2
	nStart	:= Seconds()
	nCont2	:= 1
	For nCont:=2 to 100000
		//If nCont2==1
		//	oExcel:NivelLinha(nil,.T.,.F.)
		//ElseIf nCont2==2
		//	oExcel:NivelLinha(1,.T.,.T.)
		//ElseIf nCont2>11
		//	nCont2 := 0
		//EndIf
		//nCont2++
		oExcel:SetValueBulk(nCont)
		oExcel:SetValueBulk("Filial"+cValtoChar(nCont))
		oExcel:SetValueBulk(Randomize(1,100))
		//oExcel:SetValueBulk(cValToChar(Randomize(1,3)))
		oExcel:SetValueBulk(date()+nCont)
		oExcel:SetBulkLine()
	Next
	oExcel:NivelLinha()
	oExcel:FlushBulk()
	nElapsed	:= Seconds() - nStart
	conout( "Linhas Tempo: " + LTrim( Str( nElapsed ) ) + " segundos" )
	nStart	:= Seconds()
	oExcel:Gravar(cLocal = "c:\temp", lAbrir = .F., lDelSrv = .T.)
	nElapsed	:= Seconds() - nStart
	conout( "Gravar: " + LTrim( Str( nElapsed ) ) + " segundos" )
Return

/*/{Protheus.doc} tstBulk2
Teste de limite de colunas do excel usando preenchimento em massa (bulk)
@type function
@version 1.0
@author Saulo Gomes Martins
@since 04/07/2026
/*/
Static Function tstBulk2()
	Local nCont As Numeric
	Local nCont2 As Numeric
	Local cSubTotais As Character
	Local oExcel := YExcel():New(cNomeFile = "Pasta1", cTipo = "A") As Object
	Local aCampos := {} As Array
	oExcel:ADDPlan(/*cNome*/)		//Adiciona uma planilha em branco
	// oExcel:SetDefRow(.F.,{1,4})	//Definir a coluna inicial e final da linha, importante para performace da classe
	//1-Numero da coluna,2-Tipo de conteudo(C,N,L,D),3-Logico se vai ter Formula,4-Logico se Ú datetime,5-Objeto Estilo
	For nCont:=1 to 16385	//Limite maximo de colunas do excel
		AADD(aCampos,oExcel:BulkNewField(nColuna = nCont, cTipo = "C"))
	Next

	oExcel:DefBulkLine(aCampos)
	nCont2	:= 1
	cSubTotais	:= ""
	For nCont:=2 to 16385
		oExcel:SetValueBulk("abcdefghijklmnopqrstuvxz abcdefghijklmnopqrstuvxz abcdefghijklmnopqrstuvxz "+cValtoChar(nCont))
	Next
	oExcel:SetBulkLine()
	oExcel:FlushBulk()
	oExcel:Gravar(cLocal = "c:\temp", lAbrir = .F., lDelSrv = .T.)
Return


/*/{Protheus.doc} tstFwXlsx
Teste de performance usando a classe do framework FwMsExcelXlsx como comparativo
@type function
@version 1.0
@author Saulo Gomes Martins
@since 04/07/2026
/*/
Static Function tstFwXlsx()
	Local nCont As Numeric
	Local nCont2 As Numeric
	Local oExcel := FwMsExcelXlsx():New() As Object
	Local nElapsed As Numeric
	Local nStart As Numeric
	oExcel:SetWriteinFile(.T.)
	////Habilita dados de processamento no BD e com Bulk ocorrendo com atÚ 200 mil registros.
	//lWriteDb := oExcel:SetWriteinDb(.T., 200000)
	//If !lWriteDb
	//	conout("NÒo foi possÝvel habilitar o recurso de dados em disco, o processamento consumirß a mem¾ria do servidor.")
	//EndIf
	oExcel:AddworkSheet("WorkSheet1")
	oExcel:AddTable ("WorkSheet1","Table1")
	oExcel:AddColumn("WorkSheet1","Table1","Linha",1,2,.F., )
	oExcel:AddColumn("WorkSheet1","Table1","Filial",1,1,.F., )
	oExcel:AddColumn("WorkSheet1","Table1","Venda",1,3,.F., )
	oExcel:AddColumn("WorkSheet1","Table1","Data Venda",1,4,.F., )

	nStart	:= Seconds()
	nCont2	:= 1
	For nCont:=2 to 100000
		oExcel:AddRow("WorkSheet1","Table1",{nCont,"Filial"+cValtoChar(nCont),Randomize(1,100),date()+nCont})
	Next
	nElapsed	:= Seconds() - nStart
	conout( "Linhas Tempo: " + LTrim( Str( nElapsed ) ) + " segundos" )
	nStart	:= Seconds()
	oExcel:Activate()
	oExcel:GetXMLFile("c:\temp\fwTESTE.xlsx")
	oExcel:DeActivate()
	nElapsed	:= Seconds() - nStart
	conout( "Gravar: " + LTrim( Str( nElapsed ) ) + " segundos" )
Return

/*/{Protheus.doc} YTstLeitura
Teste de performance de leitura de uma planilha jß gravada
@type function
@version 1.0
@author Saulo Gomes Martins
@since 04/07/2026
/*/
Static Function YTstLeitura()
	Local aTamLin As Array
	Local nCont As Numeric
	Local oExcel As Object
	Local nStart := Seconds() As Numeric
	Local nElapsed As Numeric

	oExcel	:= YExcel():New(cFileOpen = "c:\temp\Pasta1.xlsx")
	nElapsed	:= Seconds() - nStart
	conout( "Carregar xlsx: " + LTrim( Str( nElapsed ) ) + " segundos" )

	nStart := Seconds()
	aTamLin	:= oExcel:LinTam()
	For nCont:=aTamLin[1] to aTamLin[2]
		//fazernada(oExcel:Pos(nCont,1):GetValue())
		//fazernada(oExcel:Pos(nCont,2):GetValue())
		//fazernada(oExcel:Pos(nCont,3):GetValue())
		//fazernada(oExcel:Pos(nCont,4):GetValue())

		ConOut(oExcel:Pos(nCont,1):GetNumber())
		ConOut(oExcel:Pos(nCont,2):GetString())
		ConOut(oExcel:Pos(nCont,3):GetNumber())
		ConOut(oExcel:Pos(nCont,4):GetDate())
		//If nCont>2
		//Exit
		//EndIf
	Next
	ConOut(TIME())
	nElapsed	:= Seconds() - nStart
	conout( "Leitura: " + LTrim( Str( nElapsed ) ) + " segundos" )
	oExcel:Close()
Return

/*/{Protheus.doc} TstMerge
Teste de performance de mesclagem/formataþÒo condicional em planilha pequena
@type function
@version 1.0
@author Saulo Gomes Martins
@since 04/07/2026
/*/
User Function TstMerge()
	Local oExcel := YExcel():New("Pasta1") As Object
	Local nPosBorda2 := oExcel:Borda("ALL") As Numeric
	Local nPosBordas := oExcel:AddStyles(nborderId = nPosBorda2) As Numeric
	Local nCont As Numeric
	Local nCont2 As Numeric
	Local cSubTotais As Character
	Local oFont As Object
	Local oCorPre As Object
	Local oCorPre2 As Object
	Local oCorPre3 As Object
	Local oBorda As Object
	Local nPosVerm As Numeric
	Local nPosVerd As Numeric
	Local nPosAmar As Numeric
	Local nStart := Seconds() As Numeric
	ConOut("=================="+TIME())
	oExcel:ADDPlan(/*cNome*/)		//Adiciona uma planilha em branco
	// oExcel:SetDefRow(.F.,{1,4})	//Definir a coluna inicial e final da linha, importante para performace da classe
	oExcel:Cell(nLinha = 1, nColuna = 1, xValor = "Linha", xStyle = nPosBordas)
	oExcel:Cell(nLinha = 1, nColuna = 2, xValor = "Filial", xStyle = nPosBordas)
	oExcel:Cell(nLinha = 1, nColuna = 3, xValor = "Venda", xStyle = nPosBordas)
	oExcel:Cell(nLinha = 1, nColuna = 4, xValor = "Data Venda", xStyle = nPosBordas)
	nCont2	:= 1
	cSubTotais	:= ""
	For nCont:=2 to 10
		oExcel:Pos(nCont,1):SetValue(nCont)
		oExcel:Pos(nCont,2):SetValue("Filial"+cValtoChar(nCont))
		oExcel:Pos(nCont,3):SetValue(Randomize(1,100))
		oExcel:Pos(nCont,4):SetValue(date()+nCont)
		//oExcel:mergeCells(nCont,4,nCont,6)
	Next

	//Cria objetos para ser usado na formataþÒo
	oFont	:= oExcel:Font(nTamanho = 12, cCorRGB = "FFFFFF", cNome = "Calibri", cfamily = "2", lNegrito = .T., lItalico = .F., lSublinhado = .F., lTachado = .F.)	//Cor Branca Negrito
	oCorPre	:= oExcel:Preenc("FF0000")									//Fundo Vermelho
	oCorPre2:= oExcel:Preenc("00FF00")									//Fundo Verde
	oCorPre3:= oExcel:Preenc("FFFF00")									//Fundo Amarelo
	oBorda	:= oExcel:ObjBorda(cTipo = "ALL", cCor = "000000")							//Borda Preta
	//Cria o Estilo			oFont,oCorPreenc,oBorda
	nPosVerm	:= oExcel:ADDdxf(aFont = oFont, aCorPreenc = oCorPre, aBorda = oBorda)
	nPosVerd	:= oExcel:ADDdxf(aFont = oFont, aCorPreenc = oCorPre2, aBorda = oBorda)
	nPosAmar	:= oExcel:ADDdxf(aCorPreenc = oCorPre3, aBorda = oBorda)

	oExcel:FormatCond(cRefDe = oExcel:Ref(2,3), cRefAte = oExcel:Ref(nCont-1,3), nEstilo = nPosAmar, cOperator = "=", xFormula = "0")			//igual a zero

	oExcel:Gravar(cLocal = "c:\temp", lAbrir = .T., lDelSrv = .T.)
	ConOut("=================="+TIME()+"|FIM")
	ConOut(Seconds() - nStart)
Return

/*/{Protheus.doc} TstEdit
Teste de ediþÒo de uma planilha ja existente
@type function
@version 1.0
@author Saulo Gomes Martins
@since 04/07/2026
/*/
User Function TstEdit()
	Local oExcel := YExcel():New(cFileOpen = "C:\Temp\TESTE.xlsx") As Object
	oExcel:Pos(10,3):SetValue("TESTE")
	oExcel:Pos(11,3):SetValue("12/08/2022")
	oExcel:Save(GetTempPath())
	oExcel:OpenApp() //Abrir Excel
	oExcel:Close() //Fechar e limpar objeto
Return

/*/{Protheus.doc} tstMemoria
Teste de geraþÒo de planilha inteiramente em memoria
@type function
@version 1.0
@author Saulo Gomes Martins
@since 04/07/2026
/*/
User Function tstMemoria()
	Local oExcel := YExcel():New(cTipo = "M") As Object  //Inicia em memoria
	Local nCont As Numeric
	oExcel:ADDPlan() //Cria Planinha
	oExcel:AddTamCol(nMin = 1, nMax = 2, nWidth = 15.00)
	oExcel:Pos(1,1):SetValue("Olß Mundo") //Altera linha 1 coluna 1
	oExcel:Pos(2,1):SetValue("Segunda linha") //Altera linha 2 coluna 1
	oExcel:AddTamCol(nMin = 2, nMax = 2, nWidth = 25.00)
	oExcel:AddTamCol(nMin = 2, nMax = 3, nWidth = 35.00)
	For nCont:=1 to 30
		oExcel:Pos(Randomize(1,30),Randomize(1,30)):SetValue(nCont) //Volta para linha 1 coluna 1
	Next
	oExcel:AddPane(nySplit = 2, nxSplit = 3)
	oExcel:Save()    //Salvar
	oExcel:OpenApp() //Abrir Excel
	oExcel:Close()   //Fechar e limpar objeto
Return

/*/{Protheus.doc} tst3Excel
